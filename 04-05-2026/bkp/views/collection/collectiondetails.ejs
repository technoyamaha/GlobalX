<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Home page</title>
    <link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet">
    <link rel="stylesheet" href="/assets/css/novaStyle.css" />
    <link href="https://fonts.cdnfonts.com/css/oxanium" rel="stylesheet">
</head>

<body>

    <!-- header-section -->
    <header>
        <div class="header-main-outer">
            <div class="header-left-div-wrp">
                <div class="logo">
                    <img src="/assets/images/main-logo.svg" alt="logo" width="104" height="32">
                </div>
                <div class="threee-explore-menu">
                    <nav>
                        <ul>
                            <li><a href="#">Explore</a></li>
                            <li><a href="/user/getCollectionPage">Earn</a></li>
                            <li><a href="#">Reserve</a></li>
                        </ul>
                    </nav>
                </div>
            </div>
            <div class="header-right-div-col">
                <a href="#">
                    <img src="/assets/images/download-icon.svg" alt="icon">
                </a>
                <a href="#">
                    <img src="/assets/images/notification.svg" alt="icon">
                </a>
                <a href="#">
                    <img src="/assets/images/icon_tg_color.png" alt="icon">
                </a>
                <a href="#">
                    <img src="/assets/images/language-icon.svg" alt="icon">
                </a>
            </div>
        </div>
    </header>

    <section class="collection-detail-main-outer">
        <div class="collection-details-container">
            <div class="collection-details-wrp">
                <div class="collections-detail-left-img">
                    <img src="/assets/images/collection-details-img.png" alt="images"> 
                </div>
                <div class="cellection-details-right-main-wrp">
                    <div class="stake-section">
                        <h2>YieldCanvas USDT</h2>
                        <h3> Amount </h3>
                    <!-- Quantity Input -->
                        <div class="quantity-box">
                            <input type="text" placeholder="Please enter quantity">
                            <span class="currency">USDT</span>
                            <button class="max-btn">Max</button>
                        </div>
                        
                        <!-- Balance -->
                        <div class="balance-row">
                            <span>Balance: <strong>0 USDT</strong></span>
                            <a href="#" class="deposit-link">Deposit</a>
                        </div>
                        
                        <!-- Product info -->
                        <div class="product-info">
                            <div class="info-row">
                                <span>Amount</span>
                                <strong>100-2000</strong>
                            </div>
                            <div class="info-row">
                                <span>Daily income</span>
                                <strong>1.3%</strong>
                            </div>
                            <div class="info-row">
                                <span>Fees</span>
                                <strong>0%</strong>
                            </div>
                            <div class="info-row">
                                <span>Level restriction</span>
                                <strong>Lv1 ~ Lv6</strong>
                            </div>
                        </div>
                        
                        <!-- Stake Button -->
                        <button class="stake-btn">Stake</button>
                        
                        <!-- Rules Box -->
                        <div class="rules-box">
                            <h4>Rules Description:</h4>
                        
                            <p><strong>1. Fund Overview</strong><br>
                                Nova NFT Fund is an innovative digital asset management plan based on NFT liquidity income, aiming to provide
                                platform users with stable income opportunities. Users can choose fund pools of different terms to invest
                                according to their own needs, and help the development of Nova NFT ecology while enjoying the income.
                            </p>
                        
                            <p><strong>2. Fund Rules</strong><br>
                                <strong>a. Fund Pool Classification and Term</strong><br>
                                • The fund pool is divided into financial plans of different terms, each with a fixed investment cycle and rate
                                of return.
                            </p>
                        
                            <p><strong>b. Income Calculation Method</strong><br>
                                • The fund pool is calculated based on single-day income, without compound interest calculation.
                            </p>
                        
                            <p><strong>c. Principal and Income Withdrawal</strong><br>
                                • The principal and income deposited in the fund pool must be fully withdrawn after the end of the term.
                            </p>
                        
                            <p><strong>d. Minimum Investment Amount</strong><br>
                                • The minimum investment amount to enter the fund pool is US$200.
                            </p>
                        
                            <p><strong>e. Fund Pool Limitation</strong><br>
                                • Funds deposited in the fund pool cannot be used for reservation or pledge area.
                            </p>
                        
                            <p><strong>f. Applicable Users</strong><br>
                                • All users from VIP1 to VIP6 can participate.</p>
                        </div>
                        
                     </div>
                </div>
            </div>
        </div>
    </section>

      <!-- footer-section -->
    <footer class="footer-main-outer">
        <div class="footer-container">
            <!-- Left Section -->
            <div class="footer-left">
                <img src="/assets/images/footer-logo.svg" alt="logo" class="logo-footer" />
                <p class="footer-desc">
                    Join our mailing list to stay in the loop with our newest feature releases, NFT drops, and tips and tricks for navigating Nova
                </p>
                <div class="email-block">
                    <input type="email" placeholder="Enter your email address" />
                    <button type="button" class="subscribe-btn">Subscribe</button>
                </div>
                <div class="sns-row">
                    <a href="#" class="social-icon"><img src="/assets/images/icon-email.svg" alt="email" /></a>
                    <a href="#" class="social-icon"><img src="/assets/images/icon-twitter.svg" alt="twitter" /></a>
                    <a href="#" class="social-icon"><img src="/assets/images/icon-tiktok.svg" alt="tiktok" /></a>
                    <a href="#" class="social-icon"><img src="/assets/images/icon-discord.svg" alt="discord" /></a>
                    <a href="#" class="social-icon"><img src="/assets/images/icon-telegram.svg" alt="telegram" /></a>
                    <a href="#" class="social-icon"><img src="/assets/images/icon-facebook.svg" alt="facebook" /></a>
                    <a href="#" class="social-icon"><img src="/assets/images/icon-instagram.svg" alt="instagram" /></a>
                    <a href="#" class="social-icon"><img src="/assets/images/icon-youtube.svg" alt="youtube" /></a>
                </div>
            </div>

            <!-- Right Section -->
            <div class="footer-right">
                <div class="link-wrap">
                    <div class="resources-wrap">
                        <a href="#"><span>Docs</span></a>
                        <a href="#"><span>Blog</span></a>
                        <a href="#"><span>How to buy</span></a>
                    </div>
                    <div class="news-wrap">
                        <a href="#"><span>Invite friends</span></a>
                        <a href="#"><span>Tutorials</span></a>
                    </div>
                </div>
                <div class="download-wraps">
                    <a href="#" class="download-btn app-store">
                        <img src="/assets/images/icon_download_apple_01.png" alt="APP Store" />
                        <span>APP Store</span>
                    </a>
                    <a href="#" class="download-btn google-play">
                        <img src="/assets/images/icon_download_android_01.png" alt="Google Play" />
                        <span>Google Play</span>
                    </a>
                    <a href="#" class="download-btn apk">
                        <img src="/assets/images/icon_download_apk_01.png" alt="APK" />
                        <span>APK</span>
                    </a>
                </div>
            </div>
        </div>

    <!-- Copyright -->
        <div class="copyright copy-right-container">
            <span>© 2025 - Nova Technology, Inc</span>
            <span class="cursor-pointer">Privacy Policy</span>
            <span class="cursor-pointer">Terms of service</span>
        </div>
    </footer>

</body>
</html>