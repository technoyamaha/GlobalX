<!doctype html>
<html lang="en">

<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>Deposit</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700;800&display=swap" rel="stylesheet">

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,100;1,200;1,300;1,400;1,500;1,600;1,700;1,800;1,900&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/assets/css/novaStyle.css" />

  <style>
    :root {
      --accent: #00aaff;
      --accent-2: #00c0ff;
      --bg: #f6fbff;
      --card: #ffffff;
      --muted: #141414;
      --glass: rgba(255, 255, 255, 0.6);
      --success: #00c48c;
      --danger: #ff6b6b;
      --radius: 14px;
      --max-width: 980px;
      font-family: 'Inter', system-ui, -apple-system, 'Segoe UI', Roboto, 'Helvetica Neue', Arial;
      color-scheme: light;
    }

    * {
      box-sizing: border-box
    }

    html,
    body {
      height: 100%
    }

    body {
      margin: 0;
      /* background: linear-gradient(180deg, #f1fbff 0%, #f8fcff 60%); */
      display: flex;
      align-items: flex-start;
      justify-content: center;
      padding: 28px;
      font-size: 14px;
      color: #0f172a;
    }

    .wrap {
      width: 100%;
      max-width: var(--max-width);
      display: grid;
      grid-template-columns: 1fr;
      gap: 20px;
      align-items: start;
    }

    .card {
      /* background:linear-gradient(180deg, rgba(255,255,255,0.7), rgba(255,255,255,0.55)); */
      border-radius: var(--radius);
      padding: 20px;
      box-shadow: 0 8px 30px rgba(2, 6, 23, 0.06);
      border: 1px solid rgba(0, 0, 0, 0.03);
    }

    .balance-card {
      background: linear-gradient(135deg, rgba(0, 170, 255, 0.12), rgba(0, 170, 255, 0.04));
      border-radius: 12px;
      padding: 18px;
      display: flex;
      gap: 12px;
      align-items: center;
    }

    .balance-avatar {
      min-width: 64px;
      height: 64px;
      border-radius: 12px;
      display: grid;
      place-items: center;
      background: linear-gradient(180deg, var(--accent), #006fb3);
      color: white;
      font-weight: 700;
      font-size: 20px;
      box-shadow: 0 6px 18px rgba(0, 170, 255, 0.18);
    }

    .balance-info {
      flex: 1
    }

    .balance-info .label {
      font-size: 12px;
      color: var(--muted);
    }

    .balance-info .amount {
      font-size: 22px;
      font-weight: 700;
      margin-top: 4px
    }

    .balance-info .sub {
      font-size: 12px;
      color: var(--muted);
      margin-top: 6px
    }

    /* action-row: keep button compact and approachable */
    .action-row {
      display: flex;
      justify-content: flex-end;
      gap: 10px;
      margin-top: 14px
    }

    .btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      padding: 8px 12px;
      border-radius: 999px;
      /* pill */
      font-weight: 700;
      cursor: pointer;
      border: 1px solid transparent;
      transition: all .18s ease;
      box-shadow: 0 6px 18px rgba(2, 6, 23, 0.04);
      background: transparent;
      color: #0f172a;
      white-space: nowrap;
    }

    .btn:active {
      transform: translateY(1px)
    }

    /* compact primary deposit style */
    .btn.deposit-top {
      background: linear-gradient(90deg, var(--accent), var(--accent-2));
      color: white;
      padding: 8px 14px;
      border-radius: 10px;
      box-shadow: 0 10px 30px rgba(0, 170, 255, 0.18);
      border: 1px solid rgba(0, 0, 0, 0.04);
      font-size: 14px;
      min-width: 120px;
    }

    .btn.deposit-top:hover {
      transform: translateY(-2px);
      box-shadow: 0 14px 38px rgba(0, 170, 255, 0.22)
    }

    /* secondary small button (if needed) */
    .btn.ghost-small {
      background: transparent;
      border: 1px solid rgba(15, 23, 42, 0.06);
      color: var(--muted);
      padding: 6px 10px;
      border-radius: 8px;
      font-weight: 700
    }

    /* quick controls */
    .quick {
      margin-top: 16px;
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
    }

    .chip {
      background: rgba(0, 0, 0, 0.03);
      padding: 8px 10px;
      border-radius: 10px;
      font-weight: 600;
      font-size: 13px
    }

    /* panels */
    .panel-area {
      margin-top: 18px;
      display: grid;
      gap: 12px
    }

    .panel {
      padding: 14px;
      border-radius: 10px;
      /* background:linear-gradient(180deg, rgba(255,255,255,0.9), rgba(255,255,255,0.6)); */
      border: 1px solid rgba(14, 20, 30, 0.03);

      background: rgba(255, 255, 255, 0.08);
    }

    .field {
      display: flex;
      flex-direction: column;
      gap: 6px
    }

    label {
      font-size: 13px;
      color: var(--muted);
    }

    input[type="number"],
    input[type="text"],
    select {
      padding: 12px 10px;
      border-radius: 8px;
      border: 1px solid rgba(2, 6, 23, 0.06);
      font-size: 14px;
      outline: none;
    }

    .deposit-actions {
      display: flex;
      gap: 10px;
      margin-top: 10px;
      align-items: center;
      flex-wrap: wrap;
    }

    .secondary {
      background: transparent;
      border: 1px dashed rgba(15, 23, 42, 0.06);
      padding: 10px;
      border-radius: 8px
    }

    .preset {
      background: rgba(0, 170, 255, 0.07);
      padding: 8px 12px;
      border-radius: 8px;
      font-weight: 700;
      border: 1px solid rgba(0, 170, 255, 0.06);
      cursor: pointer;
      color: var(--muted)
    }

    .btn.proceed-small {
      padding: 8px 12px;
      border-radius: 8px;
      font-weight: 800;
      font-size: 13px;
      background: linear-gradient(90deg, var(--accent), var(--accent-2));
      color: white;
      border: 1px solid rgba(0, 0, 0, 0.04)
    }

    /* history */
    .history-panel {
     background: rgba(255, 255, 255, 0.08);
      border-radius: var(--radius);
      padding: 18px;
      box-shadow: 0 8px 30px rgba(2, 6, 23, 0.04);
      border: 1px solid rgba(0, 0, 0, 0.03);
      color: #000000;
    }

    .history-head {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 10px
    }

    .history-head h3 {
      margin: 0;
      font-size: 16px
    }

    .filter-row {
      display: flex;
      gap: 8px;
      align-items: center
    }

    .pill {
      padding: 8px 10px;
      border-radius: 999px;
      background: rgba(0, 0, 0, 0.04);
      font-weight: 600
    }

    table {
      width: 100%;
      border-collapse: collapse;
      margin-top: 12px
    }

    thead {
      font-size: 12px;
      color: var(--muted);
      text-align: left
    }

    th,
    td {
      padding: 12px 10px;
      border-bottom: 1px solid rgba(2, 6, 23, 0.03)
    }

    tbody tr:hover {
      background: linear-gradient(90deg, rgba(0, 170, 255, 0.03), transparent)
    }

    .status {
      padding: 6px 8px;
      border-radius: 8px;
      font-weight: 700;
      font-size: 12px
    }

    .status.success {
      background: rgba(0, 196, 140, 0.12);
      color: var(--success)
    }

    .status.pending {
      background: rgba(255, 171, 0, 0.08);
      color: #b36a00
    }

    .status.failed {
      background: rgba(255, 106, 106, 0.08);
      color: var(--danger)
    }



 

    /* small screens */
    @media (max-width:880px) {
      .wrap {
        padding: 14px
      }

      .action-row {
        justify-content: flex-start
      }

      .btn.deposit-top {
        min-width: 100px
      }
    .deposit-table-main-outer-pannel {
    max-width:600px;
    width: 100%;
    overflow-x: auto;
  }
  #depositHistoryBody td {
    min-width: 170px;
}
.wrap.deposit-main-outer {
    display: block;
}
    div#cryptoon-layout {
    width: 100%;
}
    }

    .muted {
      color: var(--muted);
      font-size: 13px
    }

    .tiny {
      font-size: 12px;
      color: var(--muted);
    }


