    if (!addr) return { ok: false, reason: 'Wallet address is required' };
    // basic checks for BEP20 address (starts with 0x and length)
    if (!addr.startsWith('0x')) return { ok: false, reason: 'Address should start with 0x' };
    if (addr.length < 40 || addr.length > 66) return { ok: false, reason: 'Address length looks invalid' };
    return { ok: true };
  }

  // ----- NEW: POST withdrawal instead of redirect (sends JSON in req.body) -----
  doWithdraw.addEventListener('click', async (e) => {
    e.preventDefault();

    const raw = (withdrawAmountEl.value || '').toString().trim();
    const val = Number(raw.replace(/,/g, ''));
    if (!val || isNaN(val) || val <= 0) {
      showToastMsg(false, 'Please enter a valid amount to withdraw.');
      withdrawAmountEl.focus();
      return;
    }

    const MIN_WITHDRAW = 1; 
    if (val < MIN_WITHDRAW) {
      showToastMsg(false, `Minimum withdraw is $${MIN_WITHDRAW}.`);
      withdrawAmountEl.focus();
      return;
    }

    const method = methodSelect.value;

    // if USDT selected, validate wallet address
    let wallet = null;
    let network = null;
    if (method === 'usdt') {
      wallet = walletAddressEl.value.trim();
      network = walletNetworkEl.value.trim() || 'USDT BEP20 (BSC)';
      const v = validateWalletAddress(wallet);
      if (!v.ok) {
        showToastMsg(false, v.reason);
        walletAddressEl.focus();
        return;
      }
    }

    // UI feedback
    doWithdraw.disabled = true;
    const prev = doWithdraw.innerText;
    doWithdraw.innerText = 'Processing...';

    // build payload
    const payload = {
      amount: Number(val.toFixed(2)),
      method: method
    };
    if (method === 'usdt') {
      payload.walletAddress = wallet;
      payload.walletNetwork = network;
    }

    try {
      const resp = await fetch('/api/withdraw/create', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
        credentials: 'same-origin'
      });

      const text = await resp.text();
      let json;
      try { json = JSON.parse(text); } catch (e) { json = null; }

      if (!resp.ok) {
        const message = (json && (json.message || json.error)) || (text && text.substring(0,200)) || 'Withdraw request failed';
        showToastMsg(false, message);
        doWithdraw.disabled = false;
        doWithdraw.innerText = prev;
        return;
      }

      if (json && json.url) {
        window.location.href = json.url;
        return;
      }

      // If backend returns object with status/message
     if (json && json.otp_required) {
  showToastMsg(true, 'OTP sent to your email');
  openOtpModal(json.order_id);
  return;
}

      // Fallback — treat plain 200 as success
      showToastMsg(true, 'Withdraw request sent');
      // setTimeout(() => window.location.href = '/wallet/withdraw', 1000);
    } catch (err) {
      console.error('Create withdraw error:', err);
      showToastMsg(false, 'Something went wrong while creating withdraw.');
      doWithdraw.disabled = false;
      doWithdraw.innerText = prev;
    }
  });

