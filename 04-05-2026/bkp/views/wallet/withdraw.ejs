<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>Withdraw</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700;800&display=swap" rel="stylesheet">

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,100;1,200;1,300;1,400;1,500;1,600;1,700;1,800;1,900&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/assets/css/novaStyle.css" />

<!-- Withdraw Page (full block: HTML + CSS + JS) -->
<style>
  /* --- Visual tokens like deposit UI --- */
  :root{
    --accent: #00aaff;
    --accent-2: #00c0ff;
    --bg: #f6fbff;
    --card: #ffffff;
    --muted:#141414;
    --glass: rgba(255,255,255,0.6);
    --success: #00c48c;
    --danger: #ff6b6b;
    --radius: 14px;
    --max-width: 1100px;
    font-family: Inter, system-ui, -apple-system, "Segoe UI", Roboto, "Helvetica Neue", Arial;
  }
  .wrap.withdraw-main-outer{
    width:100%;
    max-width:var(--max-width);
    margin:18px auto;
    display:grid;
    grid-template-columns: 1fr 420px;
    gap:18px;
    align-items:start;
    padding:18px;

  }

  .card{
    background: linear-gradient(180deg, rgba(255,255,255,0.9), rgba(255,255,255,0.7));
    border-radius:var(--radius);
    padding:18px;
    box-shadow: 0 8px 30px rgba(2,6,23,0.06);
    border: 1px solid rgba(0,0,0,0.03);
  }

  .card.bg-blue{ background: linear-gradient(180deg, rgba(0,170,255,0.06), rgba(0,170,255,0.02)); }

  .balance-card{
    display:flex;
    gap:12px;
    align-items:center;
    background: linear-gradient(135deg, rgba(0,170,255,0.12), rgba(0,170,255,0.04));
    padding:12px;
    border-radius:12px;
  }

  .balance-avatar{
    min-width:64px;
    height:64px;
    border-radius:12px;
    display:grid;
    place-items:center;
    background:linear-gradient(180deg,var(--accent), #006fb3);
    color:white;
    font-weight:700;
    font-size:20px;
    box-shadow: 0 6px 18px rgba(0,170,255,0.18);
  }

  .balance-info .label{font-size:12px;color:var(--muted);}
  .balance-info .amount{font-size:22px;font-weight:700;margin-top:4px}
  .balance-info .sub{font-size:12px;color:var(--muted);margin-top:6px}

  .btn{
    display:inline-flex;
    align-items:center;
    justify-content:center;
    gap:8px;
    padding:8px 12px;
    border-radius:10px;
    font-weight:700;
    cursor:pointer;
    border:1px solid transparent;
    background:transparent;
  }
  .btn.withdraw-top{
    background: linear-gradient(90deg,var(--accent), var(--accent-2));
    color:white;
    padding:10px 14px;
    border-radius:10px;
    box-shadow: 0 10px 30px rgba(0,170,255,0.12);
  }
  .btn.ghost { background:transparent;border:1px solid rgba(15,23,42,0.06); color:var(--muted); padding:8px 10px;border-radius:8px;}

  .field{display:flex;flex-direction:column; gap:6px; margin-top:8px}
  .field input[type="number"], .field input[type="text"], select{
    padding:12px 10px;border-radius:8px;border:1px solid rgba(2,6,23,0.06);font-size:14px;outline:none;width:100%;
  }
  .preset-row{display:flex;gap:8px;margin-top:10px;flex-wrap:wrap}
  .chip{background:rgba(0,0,0,0.03);padding:8px 12px;border-radius:10px;font-weight:700;cursor:pointer}

  .history-panel .history-head{display:flex;align-items:center;justify-content:space-between;gap:10px}
  table{width:100%;border-collapse:collapse;margin-top:12px}
  thead{font-size:12px;color:var(--muted);text-align:left}
  th,td{padding:12px 10px;border-bottom:1px solid rgba(2,6,23,0.03)}
  .status{padding:6px 8px;border-radius:8px;font-weight:700;font-size:12px}
  .status.success{background:rgba(0,196,140,0.12);color:var(--success)}
  .status.pending{background:rgba(255,171,0,0.08);color:#b36a00}
  .status.failed{background:rgba(255,106,106,0.08);color:var(--danger)}

  /* wallet block */
#walletInfo {
    border: 1px solid rgba(2,6,23,0.04);
    padding: 12px;
    border-radius: 10px;
    background: linear-gradient(180deg, rgba(0,170,255,0.06), rgba(0,170,255,0.02));
}
  .tiny { font-size:12px; color:var(--muted) }

  /* toast */
  .cv-toast { position: fixed; right: 18px; bottom: 18px; padding: 10px 14px; background: rgba(0,0,0,0.8); color: white; border-radius: 10px; z-index: 99999; display:none; font-size:13px; }

  @media (max-width: 980px){
    .wrap.withdraw-main-outer{ grid-template-columns: 1fr; padding:12px; display: block;}
  }

  .otp-modal {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,.6);
  display: none;
  align-items: center;
  justify-content: center;
  z-index: 9999;
}

.otp-modal.show {
  display: flex;
}

.otp-card {
  background: #fff;
  width: 100%;
  max-width: 360px;
  padding: 24px;
  border-radius: 12px;
  text-align: center;
}

.otp-card h3 {
  margin-bottom: 8px;
}

.otp-card input {
  width: 100%;
  padding: 14px;
  font-size: 22px;
  letter-spacing: 6px;
  text-align: center;
  border-radius: 8px;
  border: 1px solid #ccc;
  margin: 16px 0;
}

.otp-actions {
  display: flex;
  gap: 10px;
}

</style>


</head>

<body class="withdraw-main-body">
  <%- include('../partials/supportFloat') %>
  
    <%- include('../partials/header') %>
  
<div class="wrap withdraw-main-outer">
  <!-- Left: Main withdraw card -->
  <div class="card bg-blue">
    <div class="balance-card">
      <div class="balance-avatar">W</div>
      <div class="balance-info">
        <div class="label">Available balance</div>
     
       <div class="amount withdrawBalance"></div>
        <div class="sub">Last activity: <span id="lastActivity"></span></div>
      </div>
    </div>

    <div style="margin-top:12px; display:flex; gap:10px; justify-content:flex-end;">
      <button id="withdrawTopBtn" class="btn withdraw-top">Withdraw</button>
      <!-- <button id="quickHistoryBtn" class="btn ghost">Download CSV</button> -->
    </div>

    <div style="margin-top:14px;">
      <div class="field">
        <div style="display:flex;align-items:center;justify-content:space-between">
          <div>
            <div style="font-weight:700">Quick withdraw</div>
            <div class="tiny muted">Fast withdrawal to bank / UPI / USDT</div>
          </div>
          <div class="tiny">Method: <strong id="selectedMethod">Bank</strong></div>
        </div>
      </div>

      <div style="height:12px"></div>

      <!-- Wallet info (visible only for USDT) -->
      <div id="walletInfo" style="display:none; margin-bottom:12px;">
        <div style="font-weight:700; margin-bottom:8px; color: #00aaff;">Crypto Wallet (for USDT BEP20)</div>

        <div style="display:flex;gap:10px;align-items:center;flex-wrap:wrap;">
          <div style="flex:1; min-width:220px;">
            <label class="tiny muted" for="walletAddress">Wallet Address</label>
            <div style="display:flex; gap:8px; align-items:center; margin-top:6px;">
              <!-- user-entered wallet address -->
              <input id="walletAddress" name="walletAddress" type="text" placeholder="Enter your wallet address (BEP20)" style="width:100%; padding:10px 12px; border-radius:8px; border:1px solid rgba(2,6,23,0.06); font-family:monospace;" />
              <button id="copyWalletBtn" class="btn ghost" title="Copy wallet address" style="white-space:nowrap; padding:8px 10px;">Copy</button>
            </div>
          </div>

          <div style="min-width:160px;">
            <label class="tiny muted" for="walletNetwork">Wallet Network</label>
            <input id="walletNetwork" name="walletNetwork" readonly value="USDT BEP20 (BSC)" style="padding:10px 12px; border-radius:8px; border:1px solid rgba(2,6,23,0.06); width:100%;" />
          </div>
        </div>

        <div class="tiny muted" style="margin-top:8px">Send BEP20 USDT only — wrong network may lead to loss of funds.</div>
      </div>

      <div class="field">
        <label for="withdrawAmount">Amount</label>
        <input id="withdrawAmount" name="amount" type="number" placeholder="Enter amount (e.g. 500)" min="1" />
      </div>

      <div class="preset-row">
        <div class="chip" data-val="500">$ 500</div>
        <div class="chip" data-val="1000">$ 1,000</div>
        <div class="chip" data-val="2500">$ 2,500</div>
        <div class="chip" data-val="5000">$ 5,000</div>
      </div>

      <div style="height:10px"></div>
      <div class="deposit-actions" style="display:flex;gap:10px;align-items:center; flex-wrap:wrap;">
        <button class="btn withdraw-top" id="doWithdraw">Proceed</button>
        <div style="display:flex;gap:8px;align-items:center">
          <select id="methodSelect" name="method">            
            <option value="usdt">USDT</option>
          </select>

          <!-- <div id="methodSelect" class="method-display">USDT</div> -->
          <!-- <button class="btn ghost" id="openWithdrawSettings">Settings</button> -->
        </div>
      </div>

      <div class="help muted" style="margin-top:10px">Withdrawals may take 1-24 hours depending on the method. Minimum $1</div>
    </div>
  </div>

  <!-- Right: history & info -->
  <div class="withdraw-history-main-wrp">
    <div class="history-panel card bg-blue">
      <div class="history-head">
        <h3>Withdraw History</h3>
        <div class="filter-row">
          <select id="historyFilter">
            <option value="all">All</option>
            <option value="pending">Pending</option>
            <option value="completed">Approved</option>
            <option value="failed">Failed</option>
          </select>
        </div>
      </div>

      <div class="table-main-outer" style="margin-top:12px">
        <table aria-label="Withdraw history" id="withdrawHistoryTable">
          <thead>
            <tr>
              <th>Date</th>
              <th>Reference</th>
              <th>Method</th>
              <th>Amount</th>
              <th>Status</th>
            </tr>
          </thead>
          <tbody>
          </tbody>
        </table>
      </div>

      <div style="height:8px"></div>
      <!-- <div class="tiny muted">Showing last 5 transactions · <a href="/history/withdraw">View all</a></div> -->
    </div>

    <div style="height:12px"></div>

  </div>

    <%- include('../partials/footer') %>

</div>

<div id='cryptoon-layout' class="theme-orange">
  <div id="toast">
    <span id="toast-message"></span>
    <span id="toast-close" onclick="hideToast()"> ×</span>
  </div>
</div>

<!-- OTP MODAL -->
<div id="otpModal" class="otp-modal">
  <div class="otp-card">
    <h3>Verify Withdrawal</h3>
    <p class="muted">Enter the 6-digit OTP sent to your email</p>

    <input
      id="otpInput"
      type="text"
      maxlength="6"
      placeholder="Enter OTP"
      inputmode="numeric"
      autocomplete="one-time-code"
    />

    <div class="otp-actions">
      <button id="verifyOtpBtn" class="btn btn-primary">Verify & Submit</button>
      <button id="cancelOtpBtn" class="btn ghost">Cancel</button>
    </div>

    <div class="tiny muted" style="margin-top:10px">
      OTP valid for 15 minutes
    </div>
  </div>
</div>



<script>
  // small native toast used for messages
  function hideToast() {
    const t = document.getElementById('toast');
    t.classList.remove('show','bg-success1','bg-danger1');
  }
  function showToastMsg(ok, message, ms = 3000) {
    const t = document.getElementById('toast');
    const m = document.getElementById('toast-message');
    m.innerText = message;
    t.classList.remove('bg-success1','bg-danger1');
    t.classList.add(ok ? 'bg-success1' : 'bg-danger1','show');
    clearTimeout(t._t);
    t._t = setTimeout(() => hideToast(), ms);
  }
</script>


<script>
  document.getElementById("withdrawTopBtn").addEventListener("click", function () {
    const input = document.getElementById("withdrawAmount");
    if (!input) return;
    input.scrollIntoView({ behavior: "smooth", block: "center" });
    setTimeout(() => {
        input.focus();
        input.select();
    }, 300);
});


