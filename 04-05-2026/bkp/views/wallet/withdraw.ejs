// Replace your existing loadHistory(...) with this function
function escapeHtml(text) {
  if (text === null || text === undefined) return '';
  return String(text)
    .replace(/&/g, "&amp;")
    .replace(/</g, "&lt;")
    .replace(/>/g, "&gt;")
    .replace(/"/g, "&quot;")
    .replace(/'/g, "&#039;");
}

async function loadHistory(limit = 5, statusFilter = null) {
  const tbody = document.querySelector('#withdrawHistoryTable tbody');
  tbody.innerHTML = '<tr><td colspan="5" class="tiny muted">Loading...</td></tr>';

  try {
    const q = new URLSearchParams();
    q.set('limit', String(limit));
    if (statusFilter && statusFilter !== 'all') q.set('status', statusFilter);
    const resp = await fetch(`/api/withdraw-history?${q.toString()}`, { cache: 'no-store' });

    if (resp.status === 401) { window.location.href = '/login'; return; }

    if (!resp.ok) {
      // Show no withdraws if backend returned a non-ok status
      tbody.innerHTML = '<tr><td colspan="5" class="tiny muted" style="text-align:center;">No withdraws found.</td></tr>';
      return;
    }

    const json = await resp.json();

    // Accept several shapes but prefer json.data
    let rows = [];
    if (json && Array.isArray(json.data)) rows = json.data;
    else if (json && Array.isArray(json.withdraws)) rows = json.withdraws;
    else if (json && Array.isArray(json.rows)) rows = json.rows;

    if (!rows || rows.length === 0) {
      tbody.innerHTML = '<tr><td colspan="5" class="tiny muted" style="text-align:center;">No withdraws found.</td></tr>';
      return;
    }

    // Client-side filter if needed — map "completed" to 1 or 3
    if (statusFilter && statusFilter !== 'all') {
      const want = String(statusFilter).toLowerCase();

      rows = rows.filter(r => {
        // Normalize numeric/strings
        let sVal = r.status;
        if (typeof sVal === 'string' && /^\d+$/.test(sVal)) sVal = Number(sVal);
        const sText = (r.status_text || '').toString().toLowerCase();

        if (want === 'pending') {
          return sVal === 0 || /pend|wait/i.test(sText);
        }

        if (want === 'completed') {
          // treat 1 (Approved) and 3 (Completed) as completed/approved
          return sVal === 1 || sVal === 3 || /complete|approved|done|success/i.test(sText);
        }

        if (want === 'failed') {
          return sVal === 2 || /fail|reject|denied/i.test(sText);
        }

        // default: keep
        return true;
      });

      // if filter produced no rows, show no-withdraws message
      if (!rows.length) {
        tbody.innerHTML = '<tr><td colspan="5" class="tiny muted" style="text-align:center;">No withdraws found.</td></tr>';
        return;
      }
    }

    // limit and render
    rows = rows.slice(0, limit);
    tbody.innerHTML = '';

    rows.forEach(r => {
      // date handling (created_at may be epoch string)
      const dateRaw = r.created_at || r.time || r.today || Date.now();
      const dt = /^\d+$/.test(String(dateRaw)) ? new Date(Number(dateRaw)) : new Date(dateRaw);
      const dateStr = isNaN(dt.getTime()) ? String(dateRaw) : dt.toLocaleDateString() + ' ' + dt.toLocaleTimeString();

      // reference: prefer order_id
      const ref = r.order_id ? String(r.order_id) : (r.id ? '#W-' + r.id : '#W-' + Math.floor(Math.random() * 100000));

      const method = escapeHtml((r.method || r.type || r.payment_method || '—').toString());
      const amt = Number(r.amount || r.money || r.value || 0);

      // status normalization & UI class
      let statusVal = r.status;
      if (typeof statusVal === 'string' && /^\d+$/.test(statusVal)) statusVal = Number(statusVal);
      let statusClass = 'unknown';
      let statusText = (r.status_text && String(r.status_text).trim()) ? String(r.status_text).trim() : '';

      if (statusVal === 0) {
        statusClass = 'pending';
        statusText = statusText || 'Pending';
      } else if (statusVal === 1) {
        statusClass = 'success';
        statusText = statusText || 'Approved';
      } else if (statusVal === 3) {
        statusClass = 'success';
        statusText = statusText || 'Completed';
      } else if (statusVal === 2) {
        statusClass = 'failed';
        statusText = statusText || 'Failed';
      } else {
        // fallback heuristics from status_text
        const s = (statusText || '').toLowerCase();
        if (/pend|wait/i.test(s)) { statusClass = 'pending'; statusText = statusText || 'Pending'; }
        else if (/complete|approved|done|success/i.test(s)) { statusClass = 'success'; statusText = statusText || 'Completed'; }
        else if (/fail|reject|denied/i.test(s)) { statusClass = 'failed'; statusText = statusText || 'Failed'; }
        else { statusClass = 'unknown'; statusText = statusText || 'Unknown'; }
      }

      const tr = document.createElement('tr');
      tr.innerHTML = `
        <td>${escapeHtml(dateStr)}</td>
        <td>${escapeHtml(ref)}</td>
        <td>${method}</td>
        <td>$ ${Number(amt).toFixed(2)}</td>
        <td><span class="status ${statusClass}">${escapeHtml(statusText)}</span></td>
      `;
      tbody.appendChild(tr);
    });

  } catch (e) {
    console.warn('loadHistory failed:', e);
    tbody.innerHTML = '<tr><td colspan="5" class="tiny muted" style="text-align:center;">No withdraws found.</td></tr>';
  }
}


  loadHistory(5);

})();
</script>

<script>
$.ajax({
  url: '/api/info',
  method: 'GET',
  dataType: 'json',
  cache: false,
  success: function(res) {
    if (!res || !res.status || !res.user) {
      console.warn('/api/info returned unexpected', res);
      return;
    }

    const user = res.user;
    const lastLogin = res.last_login || (Array.isArray(res.last_5_login) ? res.last_5_login[0] : null);

    function fmtMoney(n) {
      const num = Number(n) || 0;
      return '$ ' + num.toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 });
    }

    function fmtLastLogin(l) {
      if (!l) return '—';
      const raw = l.today || l.login_at || l.time || l.created_at || l.date || l.datetime || null;
      if (!raw) {
        const v = Object.values(l)[0];
        if (!v) return '—';
        return String(v);
      }
      let dt = /^\d+$/.test(String(raw)) ? new Date(Number(raw)) : new Date(raw);
      if (isNaN(dt.getTime())) return String(raw);
      const d = dt.toLocaleDateString(undefined, { year: 'numeric', month: 'short', day: '2-digit' });
      const t = dt.toLocaleTimeString(undefined, { hour: '2-digit', minute: '2-digit' });
      return `${d} · ${t}`;
    }

    if (user.withdrawable_balance !== undefined && user.withdrawable_balance !== null) {
      $('.withdrawBalance').text(fmtMoney(user.withdrawable_balance));
    } 

      if (user.money ) $('.depositedMoney').text(fmtMoney(user.money));

    $('#lastActivity').text(fmtLastLogin(lastLogin));

  },
  error: function(xhr) {
    if (xhr && xhr.status === 401) {
      window.location.href = '/login';
      return;
    }
    console.error('/api/info error', xhr && xhr.responseText);
  }
});
</script>

<script>
let CURRENT_ORDER_ID = null;

// After withdraw/create success
async function openOtpModal(orderId) {
  CURRENT_ORDER_ID = orderId;
  document.getElementById('otpInput').value = '';
  document.getElementById('otpModal').classList.add('show');
}

// Close modal
document.getElementById('cancelOtpBtn').onclick = () => {
  document.getElementById('otpModal').classList.remove('show');
  CURRENT_ORDER_ID = null;
};

// VERIFY OTP
document.getElementById('verifyOtpBtn').onclick = async () => {
  const otp = document.getElementById('otpInput').value.trim();

  if (!otp || otp.length !== 6) {
    showToastMsg(false, 'Enter valid 6-digit OTP');
    return;
  }

  try {
    const resp = await fetch('/api/withdraw/verify-otp', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      credentials: 'same-origin',
      body: JSON.stringify({
        order_id: CURRENT_ORDER_ID,
        otp: otp
      })
    });

    const json = await resp.json();

    if (!resp.ok) {
      showToastMsg(false, json.message || 'OTP verification failed');
      return;
    }

    document.getElementById('otpModal').classList.remove('show');
    showToastMsg(true, 'Withdrawal submitted successfully');

    // reload history & balance
    setTimeout(() => window.location.reload(), 1000);

  } catch (e) {
    console.error(e);
    showToastMsg(false, 'OTP verification failed');
  }
};
</script>


