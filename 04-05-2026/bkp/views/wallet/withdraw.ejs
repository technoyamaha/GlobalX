    const text = walletAddressEl.value.trim();
    if (!text) {
      showToastMsg(false, 'No wallet address to copy');
      return;
    }
    try {
      const ta = document.createElement('textarea');
      ta.value = text;
      document.body.appendChild(ta);
      ta.select();
      document.execCommand('copy');
      document.body.removeChild(ta);
      showToastMsg(true, 'Wallet address copied');
    } catch (e) {
      console.error('copy failed', e);
      showToastMsg(false, 'Copy failed');
    }
  });


  (function () {
  localStorage.removeItem('usdt_wallet_address_v1');
})();

