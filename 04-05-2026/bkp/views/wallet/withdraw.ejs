const saved = localStorage.getItem(WALLET_KEY);
if (saved) walletAddressEl.value = saved;

walletAddressEl.addEventListener('blur', () => {
  const v = walletAddressEl.value.trim();
  if (v && USER_ID) {
    localStorage.setItem(WALLET_KEY, v);
  }
});



