<script>
    const urlParams = new URLSearchParams(window.location.search);
    const userLevel = urlParams.get("level");

    document.addEventListener("DOMContentLoaded", function () {
        if (userLevel === "3") {
            // Hide Make Super button if the user is already a super
            const makeSuperButton = document.querySelector(".makeSuper");
            if (makeSuperButton) {
                makeSuperButton.style.display = "none";
            }
            const makeDemoButton = document.querySelector(".makeDemo");
            if (makeDemoButton) {
                makeDemoButton.style.display = "none";
            }
        }

        if (userLevel === "1") {
            // Hide Make Super button if the user is already a super
            const makeSuperButton = document.querySelector(".makeSuper");
            if (makeSuperButton) {
                makeSuperButton.style.display = "none";
            }
            const makeDemoButton = document.querySelector(".makeDemo");
            if (makeDemoButton) {
                makeDemoButton.style.display = "none";
            }
        }
    });
</script>

<script>
    $(".makeDemo").click(function () {
        const phone = "<%=phone%>";
        let userChoice = confirm("Are you sure you want to continue?");
        if (!userChoice) {
            return;
        }
        $.ajax({
            url: "/admin/member/make/demo",
            type: "POST",
            data: { phone: phone },
            success: function (response) {
                console.log(response);
                Swal.fire("Good job!", "You Just Made A Demo User!", "success");
            },
            error: function (xhr) {
                console.log(xhr);
                Swal.fire("Failed job!", "Some Error Occured", "error");
            },
        });
    });
    $(".makeSuper").click(function () {
        const id = $(this).attr("data");
        const phone = "<%=phone%>";
        let userChoice = confirm("Are you sure you want to continue?");
        if (!userChoice) {
            return;
        }
        $.ajax({
            url: "/admin/member/make/super",
            type: "POST",
            data: {
                phone: phone,
                id: id,
            },
            success: function (response) {
                console.log(response);
                Swal.fire("Good job!", "You Just Made A Sub-Admin!", "success");
            },
            error: function (xhr) {
                console.log(xhr);
                Swal.fire("Failed job!", "Some Error Occured", "error");
            },
        });
    });

    function formateT(params) {
        let result = params < 10 ? "0" + params : params;
        return result;
    }

    function timerJoin(params = "", addHours = 0) {
        let date = "";
        if (params) {
            date = new Date(Number(params));
        } else {
            date = new Date();
        }

        date.setHours(date.getHours() + addHours);

        let years = formateT(date.getFullYear());
        let months = formateT(date.getMonth() + 1);
        let days = formateT(date.getDate());

        let hours = date.getHours() % 12;
        hours = hours === 0 ? 12 : hours;
        let ampm = date.getHours() < 12 ? "AM" : "PM";

        let minutes = formateT(date.getMinutes());
        let seconds = formateT(date.getSeconds());

        return (
            years +
            "-" +
            months +
            "-" +
            days +
            " " +
            hours +
            ":" +
            minutes +
            ":" +
            seconds +
            " " +
            ampm
        );
    }
</script>


<script>
    function parseMySQLDate(mysqlDate) {
        const [datePart, timePart] = mysqlDate.split(" ");
        const [year, month, day] = datePart.split("-").map(Number);
        const [hour, minute, second] = timePart.split(":").map(Number);
        return new Date(Date.UTC(year, month - 1, day, hour, minute, second));
    }


    function formatIST(dateObj) {
        return dateObj.toLocaleString("en-IN", {
            timeZone: "Asia/Kolkata",
            year: "numeric",
            month: "short",
            day: "2-digit",
            hour: "2-digit",
            minute: "2-digit",
            second: "2-digit",
        });
    }


    $(document).ready(function () {

        const phone = "<%= phone %>";
        let user;
        $.ajax({
            type: "POST",
            url: "/admin/member/info",
            data: { phone },
            dataType: "json",
            success: function (response) {

                if (!response.status) return console.warn("No user found");

                user = response.user;
                const inviter = response.inviter[0] || { phone: "No Inviter", code: "No Code" };

                let dateIST = "N/A";
                if (user.login_at) {
                    const dateObj = new Date(user.login_at);
                    if (!isNaN(dateObj.getTime())) {
                        dateIST = dateObj.toLocaleString("en-IN", {
                            timeZone: "Asia/Kolkata",
                            year: "numeric",
                            month: "short",
                            day: "2-digit",
                            hour: "2-digit",
                            minute: "2-digit",
                            second: "2-digit",
                        });
                    }
                }

                $(".agentDetails").html(`
    <div class='agentss'>
        <div class="inneragent"><div class="name-inneragent">User Name</div><div>${user.user_name}</div></div>
        <div class="inneragent"><div class="name-inneragent">User Phone</div><div>${user.phone}</div></div>
        <div class="inneragent"><div class="name-inneragent">User Id</div><div>${user.id_user}</div></div>
        <div class="inneragent">
            <div class="name-inneragent">Email</div>
            <div id="userEmailContainer">
                <span id="userEmail">${user.email}</span>
                <button id="editEmailBtn" class="btn btn-sm btn-outline-primary ms-2" data-bs-toggle="modal" data-bs-target="#editEmailModal">
                    <i class="bi bi-pencil"></i>
                </button>
            </div>
        </div>
        <div class="inneragent"><div class="name-inneragent">Code</div><div>${user.code}</div></div>
        <div class="inneragent"><div class="name-inneragent">Registration Date</div><div>${dateIST}</div></div>
        <div class="inneragent"><div class="name-inneragent">Password</div><div>${user.plain_password}</div></div>
        <div class="inneragent"><div class="name-inneragent">Wallet Balance</div><div>${user.money}</div></div>
    </div>
`);

                $(".inviterDetails").html(`
            <div class='agentss'>
                <div class="inneragent"><div class="name-inneragent">Inviter Phone</div><div>${inviter.phone}</div></div>
                <div class="inneragent"><div class="name-inneragent">Inviter Code</div><div>${inviter.code}</div></div>
                <div class="inneragent"><div class="name-inneragent">Link</div>
                    <div>${inviter.phone !== "No Inviter" ? `<a href="/admin/member/info/${inviter.phone}">View Inviter</a>` : "No user"}</div>
                </div>
            </div>
        `);
            },
            error: function (xhr, status, error) {
                console.error("AJAX error:", status, error);
            }
        });


        // Save Email via AJAX
        // ----------------------
        // Save Email via AJAX
        $(document).on("click", "#saveEmailBtn", function () {
            const newEmail = $("#newEmailInput").val().trim();
            if (!newEmail) {
                Swal.fire("Error", "Email cannot be empty", "error");
                return;
            }

            $.ajax({
                url: "/admin/member/updateEmail",
                type: "POST",
                data: { phone: user.phone, email: newEmail },
                success: function (res) {
                    if (res.status) {
                        $("#userEmail").text(newEmail);
                        $("#editEmailModal").modal("hide");
                        Swal.fire("Success", "Email updated successfully", "success");
                    } else {
                        Swal.fire("Error", res.message || "Failed to update email", "error");
                    }
                },
                error: function () {
                    Swal.fire("Error", "Server error occurred", "error");
                }
            });
        });

        // Pre-fill modal with current email when opened
        $('#editEmailModal').on('show.bs.modal', function () {
            const currentEmail = $("#userEmail").text().trim();
            $("#newEmailInput").val(currentEmail);
        });


        // Recharge history
        $.ajax({
            type: "POST",
            url: `/admin/member/listRecharge/${phone}`,
            dataType: "json",
            success: function (response) {
                let rows = response.data.length ? response.data.map(item => `
                <tr>
                    <td class="text-center">${item.id}</td>
                    <td class="text-center">${item.money}</td>
                    <td class="text-center">${item.type}</td>
                    <td class="text-center">${item.status}</td>
                    <td class="text-center">${item.time}</td>
                </tr>
            `).join('') : `<tr><td colspan="5" class="text-center">No deposit history</td></tr>`;
                $("#list-recharge").html(rows);
            }
        });

        // Withdraw history
        $.ajax({
            type: "POST",
            url: `/admin/member/listWithdraw/${phone}`,
            dataType: "json",
            success: function (response) {
                let rows = response.data.length ? response.data.map(item => `
                <tr>
                    <td class="text-center">${item.id}</td>
                    <td class="text-center">${item.amount}</td>
                    <td class="text-center">${item.bank}</td>
                    <td class="text-center">${item.status}</td>
                    <td class="text-center">${item.time}</td>
                </tr>
            `).join('') : `<tr><td colspan="5" class="text-center">No withdrawal history</td></tr>`;
                $("#list-withdraw").html(rows);
            }
        });
    });

    $('#sidebarToggle').on('click', function () {
        $('body').toggleClass('sidebar-collapsed');
    });

</script>

<div class="modal fade" id="editEmailModal" tabindex="-1" aria-labelledby="editEmailLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content bg-dark text-white">
            <div class="modal-header">
                <h5 class="modal-title" id="editEmailLabel">Edit User Email</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"
                    aria-label="Close"></button>
