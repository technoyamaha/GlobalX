<style>
    /*=======================
      Layout & Typography
    =========================*/
    body {
        font-family: 'Source Sans Pro', sans-serif;
        background-color: #121212;
        color: #f5f5f5;
    }

    h1 {
        font-size: 2rem;
        font-weight: 700;
        color: #89CFF0;
        margin-bottom: 1rem;
    }

    .text {
        padding-top: 20px;
    }

    /*=======================
      Admin Container & Buttons
    =========================*/
    .adminContainer {
        display: flex;
        justify-content: center;
        gap: 20px;
        margin-bottom: 20px;
        flex-wrap: wrap;
    }

    .add {
        padding: 12px 20px;
        font-size: 15px;
        font-weight: 600;
        color: white;
        background-color: #333;
        border: 2px solid #555;
        border-radius: 8px;
        transition: all 0.3s ease;
    }

    .add:hover {
        background-color: #308ff5;
        color: #fff;
        border-color: #308ff5;
        box-shadow: 0 0 10px rgba(48, 143, 245, 0.4);
    }

    /*=======================
      User & Inviter Boxes
    =========================*/
    .agentss {
        display: flex;
        flex-wrap: wrap;
        gap: 20px;
        padding: 20px;
        background-color: #1e1e1e;
        border-radius: 10px;
        margin-bottom: 30px;
        justify-content: center;
    }

    .inneragent {
        width: calc(20% - 20px);
        min-width: 180px;
        background-color: #292929;
        padding: 15px;
        border-radius: 8px;
        text-align: center;
        box-shadow: 0 0 8px rgba(0, 0, 0, 0.4);
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

    .inneragent:hover {
        transform: translateY(-3px);
        box-shadow: 0 0 12px rgba(255, 255, 255, 0.1);
    }

    .name-inneragent {
        font-size: 14px;
        font-weight: 600;
        color: #87cefa;
        margin-bottom: 4px;
    }

    .inneragent div:last-child {
        font-size: 15px;
        font-weight: 600;
        color: #fff;
    }

    /*=======================
      Email Edit Button
    =========================*/
    #editEmailBtn i {
        font-family: 'Bootstrap Icons' !important;
        display: inline-block;
        font-style: normal;
        vertical-align: middle;
    }

    #editEmailBtn {
        background-color: transparent;
        border: none;
        color: #87cefa;
        cursor: pointer;
        padding: 0;
        margin-left: 10px;
    }

    #editEmailBtn:hover {
        color: #fff;
    }

    /*=======================
      Tables
    =========================*/
    .table {
        margin: 0;
        font-size: 14px;
        border-collapse: collapse;
    }

    .table th,
    .table td {
        vertical-align: middle;
        padding: 12px;
    }

    .table thead th {
        background-color: #222;
        color: #87cefa;
        text-align: center;
        font-weight: 600;
    }

    .table tbody td {
        background-color: #1a1a1a;
        color: #eee;
        text-align: center;
    }

    .table-striped tbody tr:nth-child(odd) {
        background-color: #262626;
    }

    .pagination .page-link {
        background-color: #1e1e1e;
        border: 1px solid #444;
        color: #fff;
    }

    .pagination .page-link.active,
    .pagination .page-link:hover {
        background-color: #308ff5;
        color: #fff;
        border-color: #308ff5;
    }

    /*=======================
      Modal Styling
    =========================*/
    .modal-content {
        background-color: #1f1f1f;
        border: 1px solid #444;
        color: white;
    }

    .modal-header,
    .modal-footer {
        border-color: #333;
    }

    .modal-title {
        color: #87cefa;
    }

    .form-control {
        background-color: #2d2d2d;
        color: #fff;
        border: 1px solid #444;
    }

    .form-control:focus {
        background-color: #2d2d2d;
        color: #fff;
        border-color: #308ff5;
        box-shadow: 0 0 4px #308ff5;
    }

    .btn-primary {
        background-color: #308ff5;
        border-color: #308ff5;
        color: white;
        font-weight: 600;
    }

    .btn-primary:hover {
        background-color: #006fee;
        border-color: #006fee;
    }

    .btn-secondary {
        background-color: #555;
        border-color: #444;
    }

    /*=======================
      Responsive
    =========================*/
    @media screen and (max-width: 768px) {
        .inneragent {
            width: 100%;
        }

        .agentss {
            padding: 10px;
            gap: 15px;
        }

        .adminContainer {
            flex-direction: column;
            align-items: center;
            gap: 15px;
        }

        h1 {
            font-size: 1.5rem;
        }
    }
</style>

