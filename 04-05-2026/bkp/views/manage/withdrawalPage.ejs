<style>
  body {
    font-family: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif;
    /* background-color: #f9fafb;
    color: #333; */
  }
  body.bg-light {
   background: #001a3d !important;
    color: #fff;
  }

  .content-wrapper {
    margin-left: 250px;
    /* Leave space for fixed sidebar */
    /* background: #fff; */
   background: rgba(255, 255, 255, 0.08);
    border-radius: 8px;
    box-shadow: 0 2px 8px rgb(0 0 0 / 0.1);
    padding: 20px;
  }

  h1,
  h3 {
    color: #ffffff;
  }

  .form-group {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    align-items: center;
    gap: 15px;
    margin-bottom: 25px;
  }

  #search {
    flex-grow: 1;
    min-width: 250px;
    max-width: 400px;
    padding: 10px 15px;
    border-radius: 6px;
    border: 1px solid #ccc;
    font-size: 1rem;
    transition: border-color 0.2s ease-in-out;
  }

  #search:focus {
    outline: none;
    border-color: #007bff;
    box-shadow: 0 0 5px rgba(0, 123, 255, 0.5);
  }

  .total_recharge {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 1.1rem;
    font-weight: 600;
    color: #2c3e50;
  }

  #total_recharge_count {
    color: #555;
    font-weight: normal;
    font-size: 1rem;
  }

  #date_picker {
    padding: 8px 12px;
    border-radius: 6px;
    border: 1px solid #ccc;
    font-size: 1rem;
    transition: border-color 0.2s ease-in-out;
    cursor: pointer;
  }

  #date_picker:focus {
    outline: none;
    border-color: #007bff;
    box-shadow: 0 0 5px rgba(0, 123, 255, 0.5);
  }

  .card {
    border: none;
    border-radius: 8px;
    box-shadow: 0 2px 8px rgb(0 0 0 / 0.1);
  }

  .card-header {
    background-color: #007bff;
    color: #fff;
    border-top-left-radius: 8px;
    border-top-right-radius: 8px;
    padding: 12px 20px;
    font-weight: 600;
    font-size: 1.25rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .card-tools button {
    color: #fff;
    font-size: 1.1rem;
    transition: color 0.3s;
  }

  .card-tools button:hover {
    color: #d1e7ff;
  }

  table#table1 {
    width: 100%;
    border-collapse: separate;
    border-spacing: 0 10px;
  }

  table#table1 thead th {
    background-color: #f1f3f5;
    color: #495057;
    font-weight: 600;
    text-align: center;
    padding: 12px;
    border-radius: 6px;
  }

  table#table1 tbody tr {
    background-color: #fff;
    box-shadow: 0 2px 5px rgb(0 0 0 / 0.05);
    transition: background-color 0.2s ease;
  }

  table#table1 tbody tr:hover {
    background-color: #f8f9fa;
  }

  table#table1 tbody td {
    padding: 10px 12px;
    text-align: center;
    vertical-align: middle;
    font-size: 0.95rem;
  }

  .badge-success {
    background-color: #28a745;
    color: white;
    padding: 5px 12px;
    border-radius: 12px;
    font-size: 0.85rem;
  }

  .badge-danger {
    background-color: #dc3545;
    color: white;
    padding: 5px 12px;
    border-radius: 12px;
    font-size: 0.85rem;
  }

  nav.pagination {
    margin-top: 20px;
  }

  ul.pagination {
    display: flex;
    justify-content: center;
    list-style: none;
    padding-left: 0;
  }

  ul.pagination li.page-item {
    margin: 0 5px;
  }

  ul.pagination li.page-item a.page-link {
    color: #101010;
    border: 1px solid #dee2e6;
    padding: 7px 14px;
    border-radius: 5px;
    font-weight: 500;
    cursor: pointer;
    user-select: none;
    transition: background-color 0.2s ease, color 0.2s ease;
  }

  ul.pagination li.page-item a.page-link:hover {
    background-color: #007bff;
    color: white;
  }

  ul.pagination li.page-item a.page-link.active {
    background-color: #007bff;
    color: white;
    border-color: #007bff;
  }

  ul.pagination li.page-item.disabled a.page-link {
    color: #6c757d;
    pointer-events: none;
    cursor: default;
    background-color: #fff;
  }

  #toast {
    visibility: hidden;
    min-width: auto;
    background-color: #333;
    color: #fff;
    text-align: center;
    border-radius: 4px;
    padding: 16px 20px;
    position: fixed;
    z-index: 9999;
    top: 20px;
    right: 20px;
    transform: translateY(-100%);
    font-size: 16px;
    transition: all 0.4s ease-in-out;
    opacity: 0;
    display: flex;
    align-items: center;
    gap: 10px;
  }

  #toast.show {
    visibility: visible;
    opacity: 1;
    transform: translateY(0%);
  }

  #toast span#toast-close {
    font-size: 20px;
    cursor: pointer;
    opacity: 0.7;
  }
    .table-striped>tbody>tr:nth-of-type(odd)>* {
      background: #1E3A6E;
      color: #fff;
  }

  @media (max-width: 768px) {
    .content-wrapper {
      margin-left: 0;
      padding: 15px;
    }

    .form-group {
      flex-direction: column;
      align-items: stretch;
    }

    #search {
      max-width: 100%;
      margin-bottom: 15px;
    }

    .total_recharge {
      justify-content: center;
      font-size: 1rem;
    }

    #date_picker {
      max-width: 100%;
      margin: 0 auto;
    }

    table#table1 tbody td {
      font-size: 0.85rem;
      padding: 8px 6px;
    }
  }
</style>

<div class="wrapper">
  <!-- <div class="sidebar-toggle-wrapper" style="text-align: right; padding: 0 15px 10px 15px">
    <button id="sidebarToggle" class="btn btn-sm btn-light btn-tg">
      <img src="/assets/images/toggle-img.svg" alt="tg-mg" />
    </button>
  </div> -->

  <div class="content-wrapper">
    <div class="rec-recdDiv">
      <section class="content-header">
        <div class="container-fluid">
          <div class="row mb-2">
            <div class="col-sm-6">
              <h1>Withdrawal list</h1>
            </div>
          </div>
        </div>
      </section>
      <div class="form-group" style="text-align: center">
        <input type="text" id="search" placeholder="Enter the email you are looking for" />
      </div>
      <section class="content">
        <div class="card">
          <div class="card-header">
            <h3 class="card-title">Withdrawal list</h3>
            <div class="card-tools">
              <button type="button" class="btn btn-tool" data-card-widget="collapse" title="Collapse">
                <i class="fas fa-minus"></i>
              </button>
              <button type="button" class="btn btn-tool" data-card-widget="remove" title="Remove">
                <i class="fas fa-times"></i>
              </button>
            </div>
          </div>
          <div class="card-body p-0" style="overflow-y: hidden">
            <table class="table table-striped projects" id="table1">
              <thead>
                <tr>
                  <th class="text-center">ID</th>
                  <th class="text-center">E-mail</th>
                  <th class="text-center">Address</th>
                  <th class="text-center">Method</th>
                  <th class="text-center">Amount</th>
                  <th class="text-center">Transaction Id</th>
                  <th class="text-center">Time</th>
                  <th class="text-center">Status</th>
                </tr>
              </thead>
              <tbody></tbody>
            </table>
          </div>
        </div>

        <!-- Pagination Controls -->
        <nav aria-label="Page navigation example"
          class="my-3 d-flex justify-content-center align-items-center flex-wrap">
          <ul class="pagination mb-0" id="withdrawal-pagination-controls"></ul>
          <div class="d-flex align-items-center ms-3 mt-2 mt-md-0">
            <input type="number" id="jump-to-page" class="form-control form-control-sm" placeholder="Page #"
              style="width: 80px" />
            <button class="btn btn-sm btn-primary ms-2" id="jump-go">Go</button>
          </div>
        </nav>
      </section>
    </div>
  </div>
</div>

<script>
  let allWithdrawalsData = [];
  let currentPage = 1;
  const limit = 10;
  let currentSearch = "";

  function renderWithdrawals(rows) {
    if (!rows || rows.length === 0) {
      $("#table1 tbody").html(`
      <tr class="text-center"><td colspan="8">No Data...</td></tr>
    `);
      return;
    }

    const html = rows
      .map(
        (w) => `
    <tr class="text-center">
      <td>${w.id}</td>
      <td>${w.email}</td>
      <td>${w.wallet ?? "-"}</td>
      <td>${w.method ?? "-"}</td>
      <td><b>${w.amount}</b></td>
      <td>${w.remarks ?? "-"}</td>
      <td>${formatTime(w.created_at)}</td>
      <td>
       <span class="badge ${w.status === 0
            ? "bg-warning"
            : w.status === 1
              ? "bg-success"
              : w.status === 2
                ? "bg-danger"
                : w.status === 3
                  ? "bg-info"
                  : "bg-secondary"
          }">
          ${w.status === 0
            ? "Pending"
            : w.status === 1
              ? "Approved"
              : w.status === 2
                ? "Rejected"
                : w.status === 3
                  ? "Completed"
                  : "Unknown"
          }
      </span>

      </td>
    </tr>
  `
      )
      .join("");

    $("#table1 tbody").html(html);
  }

  function formatTime(ms) {
    if (!ms) return "-";
    const timestamp = typeof ms === "string" ? parseInt(ms) : ms;
    return moment(timestamp).format("YYYY-MM-DD hh:mm:ss A");
  }

  function renderWithdrawalPagination(currentPage, totalPages) {
    const pagination = $("#withdrawal-pagination-controls");
    pagination.empty();

    pagination.append(`
    <li class="page-item ${currentPage === 1 ? "disabled" : ""}">
      <a class="page-link" href="#" id="previous">Previous</a>
    </li>
  `);

    const maxButtons = 5;
    let start = Math.max(currentPage - Math.floor(maxButtons / 2), 1);
    let end = start + maxButtons - 1;
    if (end > totalPages) {
      end = totalPages;
      start = Math.max(1, end - maxButtons + 1);
    }

    for (let i = start; i <= end; i++) {
      pagination.append(`
      <li class="page-item ${i === currentPage ? "active" : ""}">
        <a class="page-link" href="#" data-page="${i}">${i}</a>
      </li>
    `);
    }

    pagination.append(`
    <li class="page-item ${currentPage === totalPages ? "disabled" : ""}">
      <a class="page-link" href="#" id="next">Next</a>
    </li>
  `);
  }

  function applyWithdrawalSearchFilter() {
    let filtered = allWithdrawalsData;

    if (currentSearch) {
      const lowerSearch = currentSearch.toLowerCase();

      filtered = allWithdrawalsData.filter((w) => {
        return (
          String(w.email || "")
            .toLowerCase()
            .includes(lowerSearch) ||
          String(w.wallet || "")
            .toLowerCase()
            .includes(lowerSearch) ||
          String(w.method || "")
            .toLowerCase()
            .includes(lowerSearch) ||
          String(w.order_id || "")
            .toLowerCase()
            .includes(lowerSearch) ||
          String(formatTime(w.created_at) || "")
            .toLowerCase()
            .includes(lowerSearch) ||
          (w.status === 0
            ? "pending"
            : w.status === 1
              ? "approved"
              : w.status === 2
                ? "rejected"
                : ""
          ).includes(lowerSearch)
        );
      });
    }

    renderWithdrawals(filtered);
  }

  function loadWithdrawals(page, type = "") {
    if (type === "Next") page += 1;
    if (type === "Previous") page -= 1;

    $.ajax({
      type: "POST",
      url: "/admin/withdrawals",
      data: {
        page,
        limit,
        search: currentSearch,
      },
      dataType: "json",
      success: function (response) {
        if (response.status) {
          if (page > response.totalWithdrawPages) return;
          currentPage = page;
          $("#text-page").text(
            `${currentPage} / ${response.totalWithdrawPages}`
          );

          allWithdrawalsData = response.datas || [];
          applyWithdrawalSearchFilter();
          renderWithdrawalPagination(currentPage, response.totalWithdrawPages);

          // Pagination controls enable/disable
          $("#previous").toggleClass("disabled", currentPage === 1);
          $("#next").toggleClass(
            "disabled",
            currentPage === response.totalWithdrawPages
          );
        } else {
          $("#table1 tbody").html(
            '<tr><td colspan="10" class="text-center">Error loading data</td></tr>'
          );
        }
      },
      error: function () {
        $("#table1 tbody").html(
          '<tr><td colspan="10" class="text-center">Server error</td></tr>'
        );
      },
    });
  }

  $("#search").on("input", function () {
    currentSearch = $(this).val().trim();
    applyWithdrawalSearchFilter();
  });

  $(document).ready(function () {
    loadWithdrawals(currentPage);

    // Handle pagination click
    $(document).on(
      "click",
      "#withdrawal-pagination-controls .page-link[data-page]",
      function (e) {
        e.preventDefault();
        const targetPage = parseInt($(this).data("page"));
        if (!isNaN(targetPage)) {
          loadWithdrawals(targetPage);
        }
      }
    );

    // Next & Previous
    $(document).on("click", "#previous", function (e) {
      e.preventDefault();
      if (currentPage > 1) loadWithdrawals(currentPage - 1);
    });

    $(document).on("click", "#next", function (e) {
      e.preventDefault();
      loadWithdrawals(currentPage + 1);
    });

    // Jump to page
    $("#jump-go").click(function () {
      const targetPage = parseInt($("#jump-to-page").val());
      if (!isNaN(targetPage) && targetPage > 0) {
        loadWithdrawals(targetPage);
      }
    });

    // Search with debounce (400ms)
    let debounceTimer;
    $("#search").on("keyup", function () {
      clearTimeout(debounceTimer);
      debounceTimer = setTimeout(() => {
        currentSearch = $(this).val().trim();
        currentPage = 1;
        loadWithdrawals(currentPage);
      }, 400);
    });
  });

  $("#sidebarToggle").on("click", function () {
    $("body").toggleClass("sidebar-collapsed");
  });
</script>