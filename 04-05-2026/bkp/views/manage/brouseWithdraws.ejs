<script>
  const WITHDRAWAL_STATUS_MAP = {
    PENDING: 0,
    APPROVED: 1,
    DENIED: 2,
  };

  let allWithdrawalsData = [];
  let currentPage = 1;
  const limit = 10;
  let currentSearch = "";

  function renderWithdrawals(rows) {
    if (!rows || rows.length === 0) {
      $("#table1 tbody").html(`
      <tr class="text-center"><td colspan="10">No Data...</td></tr>
    `);
      return;
    }

    const html = rows
      .map(
        (w) => `
      <tr class="text-center">
        <td>${w.id}</td>
        <td>${w.email}</td>
        <td>${w.wallet ?? "-"}</td>
        <td>${w.method ?? "-"}</td>
        <td><b>${Number(w.amount).toFixed(2)}</b></td>
        <td><b>${(Number(w.amount) - Number(w.fee_deduct || 0)).toFixed(2)}</b></td> <!-- Paying Amount -->
        <td>${w.order_id ?? "-"}</td>
        <td>${formatTime(w.created_at)}</td>
        <td>
          <span class="badge ${w.status === 0
            ? "bg-warning"
            : w.status === 1
              ? "bg-success"
              : w.status === 2
                ? "bg-danger"
                : w.status === 3
                  ? "bg-info"
                  : "bg-secondary"
          }">
            ${w.status === 0
            ? "Pending"
            : w.status === 1
              ? "Approved"
              : w.status === 2
                ? "Rejected"
                : w.status === 3
                  ? "Completed"
                  : "Unknown"
          }
          </span>
        </td>
        <td class="project-actions text-center" style="min-width: 160px;">
          <button class="btn btn-success btn-sm confirm-btn" data-id="${w.id}">
            <i class="fa fa-check-circle"></i>
          </button>
          <button class="btn btn-danger btn-sm delete-btn" data-id="${w.id}">
            <i class="fas fa-times-circle"></i>
          </button>
        </td>
         <!-- <td class="project-actions text-center" style="min-width: 130px;">
          <button class="btn btn-primary btn-sm pay-now-btn" data-id="${w.id}">
            <i class="fa fa-credit-card"></i> 
            <a href="/admin/withdraw/form/${w.order_id}" style="color: white; text-decoration: none;">Pay Now</a> 
          </button>
        </td>-->
      </tr>
    `
      )
      .join("");


    $("#table1 tbody").html(html);
  }

  function formatTime(ms) {
    if (!ms) return "-";
    const timestamp = typeof ms === "string" ? parseInt(ms) : ms;
    return moment(timestamp).format("YYYY-MM-DD hh:mm:ss A");
  }

  function renderWithdrawalPagination(currentPage, totalPages) {
    const pagination = $("#withdrawal-pagination-controls");
    pagination.empty();

    pagination.append(`
    <li class="page-item ${currentPage === 1 ? 'disabled' : ''}">
      <a class="page-link" href="#" id="previous">Previous</a>
    </li>
  `);

    const maxButtons = 5;
    let start = Math.max(currentPage - Math.floor(maxButtons / 2), 1);
    let end = start + maxButtons - 1;
    if (end > totalPages) {
      end = totalPages;
      start = Math.max(1, end - maxButtons + 1);
    }

    for (let i = start; i <= end; i++) {
      pagination.append(`
      <li class="page-item ${i === currentPage ? 'active' : ''}">
        <a class="page-link" href="#" data-page="${i}">${i}</a>
      </li>
    `);
    }

    pagination.append(`
    <li class="page-item ${currentPage === totalPages ? 'disabled' : ''}">
      <a class="page-link" href="#" id="next">Next</a>
    </li>
  `);
  }


  function applyWithdrawalSearchFilter() {
    let filtered = allWithdrawalsData;

    if (currentSearch) {
      const lowerSearch = currentSearch.toLowerCase();

      filtered = allWithdrawalsData.filter(w => {
        return (
          String(w.email || '').toLowerCase().includes(lowerSearch) ||
          String(w.wallet || '').toLowerCase().includes(lowerSearch) ||
          String(w.method || '').toLowerCase().includes(lowerSearch) ||
          String(w.order_id || '').toLowerCase().includes(lowerSearch) ||
          String(formatTime(w.created_at) || '').toLowerCase().includes(lowerSearch) ||
          // Add more fields if needed
          (w.status === 0 ? "pending" : w.status === 1 ? "approved" : w.status === 2 ? "rejected" : "").includes(lowerSearch)
        );
      });
    }

    renderWithdrawals(filtered);
  }

  function loadWithdrawals(page, type = "") {
    if (type === "Next") page += 1;
    if (type === "Previous") page -= 1;
    if (page < 1) return;

    $.ajax({
      type: "POST",
      url: "/admin/withdrawals",
      data: {
        page,
        limit,
        search: currentSearch, status: 0,
      },
      dataType: "json",
      success: function (response) {

        if (response.status) {
          if (page > response.totalWithdrawPages) return;
          currentPage = page;
          $("#text-page").text(`${currentPage} / ${response.totalWithdrawPages}`);

          allWithdrawalsData = response.datas || [];
          applyWithdrawalSearchFilter();

          renderWithdrawalPagination(currentPage, response.totalWithdrawPages);

          // Pagination controls enable/disable
          $("#previous").toggleClass("disabled", currentPage === 1);
          $("#next").toggleClass("disabled", currentPage === response.totalWithdrawPages);
        } else {
          $("#table1 tbody").html('<tr><td colspan="10" class="text-center">Error loading data</td></tr>');
        }
      },
      error: function () {
        $("#table1 tbody").html('<tr><td colspan="10" class="text-center">Server error</td></tr>');
      }
    });
  }
  $("#search").on("input", function () {
    currentSearch = $(this).val().trim();
    applyWithdrawalSearchFilter();
  });


  $(document).ready(function () {
    loadWithdrawals(currentPage);

    $(document).on("click", "#withdrawal-pagination-controls .page-link[data-page]", function (e) {
      e.preventDefault();
      const targetPage = parseInt($(this).data("page"));
      if (!isNaN(targetPage)) {
        loadWithdrawals(targetPage);
      }
    });

    // Next & Previous
    $(document).on("click", "#previous", function (e) {
      e.preventDefault();
      if (currentPage > 1) loadWithdrawals(currentPage - 1);
    });

    $(document).on("click", "#next", function (e) {
      e.preventDefault();
      loadWithdrawals(currentPage + 1);
    });

    // Jump to page
    $("#jump-go").click(function () {
      const targetPage = parseInt($("#jump-to-page").val());
      if (!isNaN(targetPage) && targetPage > 0) {
        loadWithdrawals(targetPage);
      }
    });


    // Search with debounce (400ms)
    let debounceTimer;
    $("#search").on("keyup", function () {
      clearTimeout(debounceTimer);
      debounceTimer = setTimeout(() => {
        currentSearch = $(this).val().trim();
        currentPage = 1; // reset page to 1 on search
        loadWithdrawals(currentPage);
      }, 400);
    });
  });

  $("#sidebarToggle").on("click", function () {
    $("body").toggleClass("sidebar-collapsed");
  });
</script>

<script>
  $(document).on("click", ".btn-success.confirm-btn", function () {
    const id = $(this).data("id");
    const phone = $(this).closest("tr").find("td").eq(1).text();


    $(".popup_root").css("display", "flex");
    $("#popup_action_label").text("Approve");
    $("#popup_phone_label").text(phone);


    $("#remarks_field_label").show();
    $("#remarks_field").show();
    $("#password_field_label").hide();
    $("#password_field").hide();

    // Submit logic
    $("#submit_btn").off("click.submit").on("click.submit", async function () {
      try {
        const remarks = $("#remarks_field").val().trim();
        const response = await axios.post("/api/webapi/withdraw/status", {
          id,
          status: WITHDRAWAL_STATUS_MAP.PENDING,
          remarks,
        });

        Swal.fire("Approved!", response.data.message, "success");
        $(".popup_root").hide();
        window.location.reload()
        await loadWithdrawals(currentPage);
      } catch (err) {
        console.log(err)
        Swal.fire("Error", err.response?.data?.message || "Something went wrong", "error");
      } finally {
        $("#remarks_field").val("");
      }
    });
  });

  // REJECT BUTTON HANDLER
  $(document).on("click", ".btn-danger.delete-btn", function () {
    const id = $(this).data("id");
    const phone = $(this).closest("tr").find("td").eq(1).text();
    $(".popup_root").css("display", "flex");
    $("#popup_action_label").text("Reject");
    $("#popup_phone_label").text(phone);

    $("#remarks_field_label").show();
    $("#remarks_field").show();
    $("#password_field_label").hide();
    $("#password_field").hide();

    $("#submit_btn").off("click.submit").on("click.submit", async function () {
      try {
        const remarks = $("#remarks_field").val().trim();
        const response = await axios.post("/api/webapi/withdraw/status", {
          id,
          status: WITHDRAWAL_STATUS_MAP.DENIED,
          remarks,
        });
        Swal.fire("Rejected!", response.data.message, "success");
        $(".popup_root").hide();
        window.location.reload()
        await loadWithdrawals(currentPage);
      } catch (err) {
        Swal.fire("Error", err.response?.data?.message || "Something went wrong", "error");
      } finally {
        $("#remarks_field").val("");
      }
    });
  });

  // CANCEL BUTTON HANDLER
  $("#cancel_btn").click(function () {
    $(".popup_root").hide();
    $("#remarks_field").val("");
    $("#password_field").val("");
  });

</script>