<script>
  let allRechargeData = [];
  let rechargePage = 1, rechargeLimit = 10, searchQuery = "";
  const PaymentMethodsMap = {
    upi_gateway: "UPI GATEWAY",
    upi_gatewa: "UPI GATEWAY",
    upi_manual: "UPI Manual",
    usdt_manual: "USDT Manual",
    wow_pay: "WOW Pay",
    usdt: "USDT",
    india_pay: "INDIA PAY",
    zynte_pay: "ZYNTE PAY"
  };

  // function formatTime(ts = '', addHours = 0) {
  //   let date = ts ? new Date(Number(ts)) : new Date();
  //   date.setHours(date.getHours() + addHours);
  //   const yyyy = date.getFullYear();
  //   const mm = ('0' + (date.getMonth() + 1)).slice(-2);
  //   const dd = ('0' + date.getDate()).slice(-2);
  //   let h = date.getHours() % 12 || 12;
  //   const ampm = date.getHours() < 12 ? "AM" : "PM";
  //   const min = ('0' + date.getMinutes()).slice(-2);
  //   const sec = ('0' + date.getSeconds()).slice(-2);
  //   return `${yyyy}-${mm}-${dd} ${h}:${min}:${sec} ${ampm}`;
  // }

  function formatTime(ts) {
  if (!ts) return '-';

  const ms = Number(ts);
  if (isNaN(ms)) return '-';

  const d = new Date(ms);

  const yyyy = d.getFullYear();
  const mm = String(d.getMonth() + 1).padStart(2, '0');
  const dd = String(d.getDate()).padStart(2, '0');

  let h = d.getHours();
  const ampm = h >= 12 ? 'PM' : 'AM';
  h = h % 12 || 12;

  const min = String(d.getMinutes()).padStart(2, '0');
  const sec = String(d.getSeconds()).padStart(2, '0');

  return `${yyyy}-${mm}-${dd} ${h}:${min}:${sec} ${ampm}`;
}


  function renderRecharge(rows) {
    const tbody = $("#table1 tbody");
    if (!rows || rows.length === 0) {
      tbody.html(`<tr class="text-center"><td colspan="9">No data...</td></tr>`);
      return;
    }

    const html = rows.map(data => `
      <tr class="text-center">
        <td>${data.id}</td>
        <td><b>${data.email ?? ''}</b></td>
         <td style="min-width:190px;"><b>${PaymentMethodsMap?.[data.type] ?? data.type}</b></td>
        <td><b>${data.money}</b></td>
        <td><b>${data.inr_amount}</b></td>
        <td style="min-width:190px;"><b>${data.id_order}</b></td>
        <td style="min-width:190px;"><b>${data.wallet_id}</b></td>
        <td style="min-width:190px;"><b>${data.utr}</b></td>       
        <td style="min-width:190px;"><b>${formatTime(data.time)}</b></td>
        <td>
          <span class="badge badge-${data.status == 1 ? 'success' : 'danger'}">
            ${data.status == 1 ? 'Success' : (data.status == 0 ? 'Pending' : 'Closed')}
          </span>
        </td>
      </tr>
    `).join('');

    tbody.html(html);
  }

  function applyClientSearchFilter() {
    let filtered = allRechargeData;

    if (searchQuery) {
      const lowerSearch = searchQuery.toLowerCase();
      filtered = allRechargeData.filter(item => {
        return (
          String(item.email || '').toLowerCase().includes(lowerSearch) ||
          String(item.type || '').toLowerCase().includes(lowerSearch) ||
          String(item.money || '').toLowerCase().includes(lowerSearch) ||
          String(item.id_order || '').toLowerCase().includes(lowerSearch) ||
          String(item.utr || '').toLowerCase().includes(lowerSearch) ||
          String(formatTime(item.time) || '').toLowerCase().includes(lowerSearch) ||
          (item.status == 1 ? "success" : item.status == 0 ? "pending" : "closed").includes(lowerSearch)
        );
      });
    }

    renderRecharge(filtered);
  }

  function renderPagination(currentPage, totalPages) {
    const pagination = $("#pagination-controls");
    pagination.empty();

    pagination.append(`
    <li class="page-item ${currentPage === 1 ? 'disabled' : ''}">
      <a class="page-link" href="#" id="previous">Previous</a>
    </li>
  `);

    const maxButtons = 5;
    let start = Math.max(currentPage - Math.floor(maxButtons / 2), 1);
    let end = start + maxButtons - 1;
    if (end > totalPages) {
      end = totalPages;
      start = Math.max(1, end - maxButtons + 1);
    }

    // Page numbers
    for (let i = start; i <= end; i++) {
      pagination.append(`
      <li class="page-item ${i === currentPage ? 'active' : ''}">
        <a class="page-link" href="#" data-page="${i}">${i}</a>
      </li>
    `);
    }

    // Next button
    pagination.append(`
    <li class="page-item ${currentPage === totalPages ? 'disabled' : ''}">
      <a class="page-link" href="#" id="next">Next</a>
    </li>
  `);
  }


  function loadRecharge(page, type = "") {
  if (type === "Next") page += 1;
  if (type === "Previous") page -= 1;
  if (page < 1) return;

  $.post(
    "/admin/recharge",
    {
      page,
      limit: rechargeLimit,
      search: searchQuery
    },
    function (res) {
      if (!res || !res.status) {
        renderRecharge([]);
        renderPagination(1, 0);
        return;
      }
      rechargePage = page;
      const totalPages = res.totalRechargesPages || 0;
      $("#text-page").text(
        totalPages > 0 ? `${page} / ${totalPages}` : "0 / 0"      );
      renderRecharge(res.datas || []);
      renderPagination(rechargePage, totalPages);
      if (res.totalRechargeAmount !== undefined) {
        $("#recharge_value").text(res.totalRechargeAmount);
      }
    }
  );
}


  $(document).ready(function () {
    loadRecharge(rechargePage);

    $("#next").click((e) => { e.preventDefault(); loadRecharge(rechargePage, "Next"); });
    $("#previous").click((e) => { e.preventDefault(); if (rechargePage > 1) loadRecharge(rechargePage, "Previous"); });


    let debounceTimer;
    $("#search").on("keyup", function () {
      clearTimeout(debounceTimer);
      debounceTimer = setTimeout(() => {
        searchQuery = $(this).val().trim();
        rechargePage = 1;
        loadRecharge(rechargePage);
      }, 400);
    });

    $(document).on("click", "#pagination-controls .page-link[data-page]", function (e) {
      e.preventDefault();
      const targetPage = parseInt($(this).data("page"));
      if (!isNaN(targetPage)) {
        loadRecharge(targetPage);
      }
    });

    $(document).on("click", "#previous", function (e) {
      e.preventDefault();
      if (rechargePage > 1) {
        loadRecharge(rechargePage - 1);
      }
    });

    $(document).on("click", "#next", function (e) {
      e.preventDefault();
      loadRecharge(rechargePage + 1);
    });

    $("#jump-go").click(function () {
      const targetPage = parseInt($("#jump-to-page").val());
      if (!isNaN(targetPage) && targetPage > 0) {
        loadRecharge(targetPage);
      }
    });

  });


</script>

