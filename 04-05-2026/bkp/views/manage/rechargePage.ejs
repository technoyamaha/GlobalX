    getTotalRecharge(startDate, enddate);
  });
  $("#date_picker").on("change", function () {
    startDate = moment(this.value).valueOf();
    enddate = startDate + 86399000;
    getTotalRecharge(startDate, enddate);
  });
  const getTotalRecharge = async (first, last) => {
    const response = await fetch(
      `/admin/totalrecharge?start=${first}&end=${last}`,
    );
    const data = await response.json();
    if (data.total_value == null) {
      console.log("isnull");
      total_recharge.text(0);
    } else {
      console.log(data.total_value);
      total_recharge.text(data.total_value);
    }
  };
  getTotalRecharge(startDate, enddate);

  $('#sidebarToggle').on('click', function () {
    $('body').toggleClass('sidebar-collapsed');
  });
</script>