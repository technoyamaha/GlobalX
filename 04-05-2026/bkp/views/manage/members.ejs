  <div class="content-wrapper">
    <section class="content-header">
      <div class="container-fluid d-flex justify-content-between align-items-center">
        <h1>Members List</h1>
      </div>
    </section>
    <div class="d-flex justify-content-end div-sr-cl">
      <input type="text" id="search" class="form-control" placeholder="Enter the member you are looking for.." />
    </div>
    <section class="content">
      <div class="card">
        <div class="card-header bg-primary text-white">
          <h3 class="card-title"><i class="fa fa-users"></i> All Members</h3>
          <div class="card-tools">
            <button type="button" class="btn btn-tool" data-card-widget="collapse">
              <i class="fas fa-minus"></i>
            </button>
          </div>
        </div>
        <div class="card-body p-0">
          <div class="table-responsive">
            <table class="table table-hover table-striped projects" id="table1">
              <thead class="table-dark">
                <tr>
                  <th class="text-center">#</th>
                  <th class="text-center">E-mail</th>
                  <th class="text-center">Level</th>
                  <th class="text-center">Total Deposit</th>
                  <th class="text-center">Wallet Balance</th>
                  <th class="text-center">Withdraw Balance</th>
                  <th class="text-center">Total Withdrawal</th>
                  <th class="text-center">Status</th>
