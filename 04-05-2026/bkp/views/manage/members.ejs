<!-- Wallet Credit Debit Modal -->
<div class="modal fade" id="walletAdjustModal" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">

      <div class="modal-header">
        <h5 class="modal-title">Adjust Withdrawable Balance</h5>
        <button class="btn-close" data-bs-dismiss="modal"></button>
      </div>

      <div class="modal-body">
        <p class="mb-1"><strong>User:</strong> <span id="walletUserName"></span></p>
        <p class="mb-3">
          <strong>Withdrawable Balance:</strong> $<span id="walletUserBalance"></span>
        </p>

        <select id="walletAction" class="form-control mb-3">
          <option value="">Select Action</option>
          <option value="credit">Credit (+)</option>
          <option value="debit">Debit (-)</option>
        </select>

        <input
          type="number"
          min="0"
          step="0.01"
          id="walletAmount"
          class="form-control"
          placeholder="Enter amount"
        />

      </div>

      <div class="modal-footer">
        <button class="btn btn-secondary" data-bs-dismiss="modal">
          Cancel
        </button>
        <button class="btn btn-primary" id="confirmWalletAdjustBtn">
          Confirm
        </button>
      </div>

    </div>
  </div>
</div>

<div id="cryptoon-layout" class="theme-orange">
  <div id="toast">
    <span id="toast-message"></span>
    <span id="toast-close" onclick="hideToast()"> ×</span>
  </div>
</div>


<script>

  function showToast(status, message) {
    const toast = document.getElementById("toast");
    const toastMessage = document.getElementById("toast-message");
    let toastTimeout;

    toastMessage.innerText = message;

    toast.classList.remove("bg-success1", "bg-danger1");
    toast.classList.add(status ? "bg-success1" : "bg-danger1");
    toast.classList.add("show");

    clearTimeout(toastTimeout);
    toastTimeout = setTimeout(() => {
      hideToast();
    }, 3000);
  }

  function renderMemberPagination(currentPage, totalPages) {
    const pagination = $("#member-pagination-controls");
    pagination.empty();

    // Previous Button
    pagination.append(`
    <li class="page-item ${currentPage === 1 ? "disabled" : ""}">
      <a class="page-link" href="#" id="previous">Previous</a>
    </li>
  `);

    const maxButtons = 5;
    let start = Math.max(currentPage - Math.floor(maxButtons / 2), 1);
    let end = start + maxButtons - 1;
    if (end > totalPages) {
      end = totalPages;
      start = Math.max(1, end - maxButtons + 1);
    }

    // Numbered page buttons
    for (let i = start; i <= end; i++) {
      pagination.append(`
      <li class="page-item ${i === currentPage ? "active" : ""}">
        <a class="page-link" href="#" data-page="${i}">${i}</a>
      </li>
    `);
    }

    // Next Button
    pagination.append(`
    <li class="page-item ${currentPage === totalPages ? "disabled" : ""}">
      <a class="page-link" href="#" id="next">Next</a>
    </li>
  `);
  }

  let pageno = 1,
    limit = 20,
    searchMember = "",
    currentUserId = null;
  const Render = (datas) => {
    let html = "";
    if (!datas || datas.length === 0) {
      $("tbody").html(
        '<tr><td colspan="9" class="text-center">🚫 No Members Found</td></tr>'
      );
      return;
    }

    datas.forEach((data) => {
      html += `
            <tr class="text-center">
              <td>${data.id_user}</td>
              <td><b class="text-primary">${data.email}</b></td>
              <td><b class="${data.level == 1
          ? "text-danger"
          : data.level == 3
            ? "text-info"
            : data.level == 5
              ? "text-warning"
              : "text-secondary"
        }">${data.level == 1
          ? "Admin"
          : data.level == 3
            ? "Agent"
            : data.level == 5
              ? "Predictor"
              : "User"
        }</b></td>
              <td>${data.total_recharge || 0}</td>
              <td><b>${data.money || 0}</b></td>
              <td>
  <b class="text-success">
    ${Number(data.withdrawable_balance || 0).toFixed(2)}
  </b>
</td>
              <td>${data.total_withdrawal || 0}</td>
              <td>${data.status == 1
          ? '<span class="badge bg-success">Active</span>'
          : '<span class="badge bg-danger">Banned</span>'
        }</td>
              <td><span class="text-muted">${data.plain_password || "-"
        }</span></td>
              
        
        <!-- <td class="project-actions text-center">
                <a class="btn btn-primary btn-sm" href="/admin/member/info/${data.phone
        }">
                  <i class="fa fa-user"></i>
                </a>               
                ${data.status == 1
          ? `<a class="btn btn-danger btn-sm lock-btn" data-id="${data.id}"><i class="fa fa-lock"></i></a>`
          : `<a class="btn btn-success btn-sm unlock-btn" data-id="${data.id}"><i class="fa fa-unlock"></i></a>`
        }
              </td> -->
              
              
              <td class="project-actions text-center">
  <a class="btn btn-primary btn-sm" href="/admin/member/info/${data.phone}">
    <i class="fa fa-user"></i>
  </a>

  <button 
    class="btn btn-warning btn-sm wallet-adjust-btn"
    data-id="${data.id}"
    data-name="${data.email}"
    data-balance="${data.withdrawable_balance || 0}">
    <i class="fa fa-wallet"></i>
  </button>

  ${data.status == 1
    ? `<a class="btn btn-danger btn-sm lock-btn" data-id="${data.id}">
        <i class="fa fa-lock"></i>
       </a>`
    : `<a class="btn btn-success btn-sm unlock-btn" data-id="${data.id}">
        <i class="fa fa-unlock"></i>
       </a>`
  }
</td>

            </tr>`;
    });
    $("tbody").html(html);
  };

  const loadPage = (page, search = "", type = "") => {
    if (type === "Next") page += 1;
    if (type === "Previous") page -= 1;

    if (page < 1) return;

    $.post("/admin/listMember", { pageno: page, limit, search }, (response) => {
      if (response.status) {
        if (page > response.page_total) return;

        pageno = page;
        $("#text-page").text(`${pageno} / ${response.page_total}`);
        Render(response.datas);

        renderMemberPagination(pageno, response.page_total);
      }
    });
  };


  // Initial load
  loadPage(pageno, searchMember);

  // Pagination
  $("#next").click((e) => {
    e.preventDefault();
    loadPage(pageno, searchMember, "Next");
  });
  $("#previous").click((e) => {
    e.preventDefault();
    if (pageno > 1) loadPage(pageno, searchMember, "Previous");
  });
  // Numbered page clicks
  $(document).on("click", "#member-pagination-controls .page-link[data-page]", function (e) {
    e.preventDefault();
    const targetPage = parseInt($(this).data("page"));
    if (!isNaN(targetPage)) {
      loadPage(targetPage, searchMember);
    }
  });

  // Previous button
  $(document).on("click", "#previous", function (e) {
    e.preventDefault();
    if (pageno > 1) {
      loadPage(pageno, searchMember, "Previous");
    }
  });

  // Next button
  $(document).on("click", "#next", function (e) {
    e.preventDefault();
    loadPage(pageno, searchMember, "Next");
  });

  // Jump-to-page
  $("#jump-go").click(function () {
    const targetPage = parseInt($("#jump-to-page").val());
    if (!isNaN(targetPage) && targetPage > 0) {
      loadPage(targetPage, searchMember);
    }
  });


  let searchTimeout;
  $("#search").on("keyup", function () {
    clearTimeout(searchTimeout);
    searchTimeout = setTimeout(() => {
      searchMember = $(this).val().trim();
      pageno = 1;
      loadPage(pageno, searchMember);
    }, 300);
  });

  // Edit modal
  function openEditModal(id) {
    currentUserId = id;
    new bootstrap.Modal(document.getElementById("editModal")).show();
  }

  function saveEdit() {
    const newLevel = $("#statusSelect").val();
    if (!newLevel) return showToast(false, "Select a valid level!");
    // alert("Select a valid level!");
    $.post(
      "/admin/updateUserLevel",
      { userId: currentUserId, level: +newLevel },
      () => location.reload()
    );
  }

  // Lock/Unlock actions
  $(document).on("click", ".lock-btn", function () {
    const id = $(this).data("id");
    if (confirm("Lock this account?")) {
      $.post("/admin/banned", { id, type: "close" }, () => location.reload());
    }
  });
  $(document).on("click", ".unlock-btn", function () {
    const id = $(this).data("id");
    if (confirm("Unlock this account?")) {
      $.post("/admin/banned", { id, type: "open" }, () => location.reload());
    }
  });
  $("#sidebarToggle").on("click", function () {
    $("body").toggleClass("sidebar-collapsed");
  });


  let walletUserId = null;
let walletModal = new bootstrap.Modal(
  document.getElementById("walletAdjustModal")
);

// Open modal
$(document).on("click", ".wallet-adjust-btn", function () {
  walletUserId = $(this).data("id");
  const email = $(this).data("name");
  const balance = Number($(this).data("balance") || 0);
  $("#walletUserBalance").text(balance.toFixed(2));
  $("#walletUserName").text(email);
  $("#walletAction").val("");
  $("#walletAmount").val("");

  walletModal.show();
});

// Confirm credit / debit
$("#confirmWalletAdjustBtn").on("click", function () {
  const action = $("#walletAction").val();
  const amount = Number($("#walletAmount").val());

  if (!action) return showToast(false, "Select credit or debit");
  if (!amount || amount <= 0) return showToast(false, "Enter valid amount");

  $(this).prop("disabled", true);

 $.ajax({
  url: "/admin/adjustWithdrawableBalance",
  method: "POST",
  contentType: "application/json",
  data: JSON.stringify({
    userId: walletUserId,
    action,
    amount
  }),
  success: function (res) {
    if (res && res.status) {
      walletModal.hide();
      setTimeout(() => {
        showToast(true, res.message || "Wallet updated successfully");
      }, 500);

      setTimeout(() => {
        location.reload();
      }, 1500);

    } else {
      showToast(false, res.message || "Operation failed");
    }
  },
  error: function () {
    showToast(false, "Request failed");
  },
  complete: function () {
    $("#confirmWalletAdjustBtn").prop("disabled", false);
  }
});


});


</script>