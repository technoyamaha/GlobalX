  .content-wrapper {
    margin-left: 250px;
    padding: 30px 25px;
    /* background: #f4f6f9; */
    background: rgba(255, 255, 255, 0.08);
    min-height: 100vh;
    color: #fff;
  }

  .card {
    border: none;
    box-shadow: 0 0 20px rgba(0, 0, 0, 0.05);
    border-radius: 10px;
    overflow: hidden;
  }

  .card-header {
    background-color: #007bff !important;
    color: white;
    font-weight: bold;
    padding: 1rem 1.5rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .card-title i {
    margin-right: 8px;
  }

  .card-body {
    padding: 20px;
