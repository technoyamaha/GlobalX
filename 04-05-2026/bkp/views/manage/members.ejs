  }

  #search:focus {
    border-color: #007bff;
    box-shadow: 0 0 5px rgba(0, 123, 255, 0.3);
    outline: none;
  }

  .table thead th {
    /* background-color: #343a40; */
    background-color: #1E3A6E;
    color: white;
    text-align: center;
  }
  table#table1 .text-muted {
    color: #fff !important;
}

  .table td,
  .table th {
    text-align: center;
    vertical-align: middle;
  }

  .table-hover tbody tr:hover {
    background-color: #f1f1f1;
  }

  .btn-sm {
    padding: 0.3rem 0.5rem;
    font-size: 0.85rem;
  }

  .pagination .page-link {
    color: #101010;
    border: 1px solid #dee2e6;
    border-radius: 6px;
    margin: 0 2px;
  }

  .pagination .page-link.active {
    background-color: #007bff;
    border-color: #007bff;
    color: white !important;
  }

  /* Modal */
  .modal-content {
    border-radius: 12px;
  }

  .modal-header {
    background-color: #007bff;
    color: white;
    border-bottom: 1px solid #dee2e6;
  }

  .modal-footer .btn-primary {
    background-color: #007bff;
    border-color: #007bff;
  }

  .btn-primary:hover,
  .btn-danger:hover,
  .btn-success:hover {
    opacity: 0.9;
    transition: 0.3s ease-in-out;
  }

    .members-main-wrp .table-striped>tbody>tr:nth-of-type(odd)>* {
      background: #1E3A6E;
      color: #fff;
  }

  
  #toast {
    visibility: hidden;
    min-width: auto;
    background-color: #333;
    color: #fff;
    text-align: center;
    border-radius: 4px;
    padding: 16px 20px;
    position: fixed;
    z-index: 9999;
    top: 20px;
    right: 20px;
    transform: translateY(-100%);
    font-size: 16px;
    transition: all 0.4s ease-in-out;
    opacity: 0;
    display: flex;
    align-items: center;
    gap: 10px;
  }

  #toast.show {
    visibility: visible;
    opacity: 1;
    transform: translateY(0%);
  }

  #toast span#toast-close {
    font-size: 20px;
    cursor: pointer;
    opacity: 0.7;
  }


  @media (max-width: 768px) {
    #search {
      width: 90%;
    }

    .content-wrapper {
      margin-left: 0;
    }
  }
</style>

