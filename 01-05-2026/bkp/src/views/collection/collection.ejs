  <!-- collection-tab-js -->
  <script>
    const tabContainer = document.querySelector('.products-tabs');
    const tabButtons = tabContainer.querySelectorAll('[role="tab"]');
    const tabPanels = Array.from(tabContainer.querySelectorAll('[role="tabpanel"]'));

    function tabClickHandler(e) {
      // Hide all panels
      tabPanels.forEach(panel => {
        panel.hidden = true;
      });

      // Reset all tabs
      tabButtons.forEach(button => {
        button.setAttribute('aria-selected', 'false');
      });

      // Activate clicked tab
      e.currentTarget.setAttribute('aria-selected', 'true');

      // Show matching panel
      const id = e.currentTarget.id;
      const currentPanel = tabPanels.find(
        panel => panel.getAttribute('aria-labelledby') === id
      );

      currentPanel.hidden = false;
    }

    tabButtons.forEach(button => {
      button.addEventListener('click', tabClickHandler);
    });
  </script>
