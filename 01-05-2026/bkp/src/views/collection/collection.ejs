<script>
$(document).ready(function () {
  async function loadPlans() {
    try {
      const response = await $.ajax({
        url: "/api/plans", 
        method: "GET"
      });

      if (!response.success) {
        console.error("Failed to fetch plans");
        return;
      }

      const plans = response.data;

      // container where all boxes will go
      const container = $(".canvas-tabpannel-main-outer");
      container.empty();

      plans.forEach(function (plan) {
        const min = plan.min;
        const max = plan.max === null ? "Unlimited" : plan.max;

        const box = `
          <div class="canvas-box">
            <div class="cnvas-top-img-wrp">
              <img src="/assets/images/collection-tab-img-1.png" alt="image">
              <div class="blue-right-corner-wrp">
                <span><img src="/assets/images/collection-tab-right-icon.svg" alt="image"></span>
                <span>${plan.daily_percent}%</span>
              </div>
            </div>

            <div class="canvas-bottom-cnt-wrp">
              <h4>${plan.name}</h4>
              
              <div class="amount-canvas-wrp">
                <div class="amount-1st">
                  <span>Amount</span>
                  <span class="green-amount">${min} - ${max}</span>
                </div>

                <div class="amount-1st">
                  <span>Daily income</span>
                  <span class="card-rate-daily-income">${plan.daily_percent}%</span>
                </div>

                <div class="amount-1st">
                  <span>Fees</span>
                  <span class="card-rate-daily-income">0%</span>
                </div>
              </div>

              <div class="canvas-days-wrp">
                <div class="days-ten-outer">
                  <span>Time</span>
                  <span class="days-ten-highilited">${plan.months} months</span>
                </div>
                <div class="level-canvas-div">
                  <span>Level:</span>
                  <span class="green">Lv1 ~ Lv6</span>
                </div>
              </div>

              <button> Details </button>
            </div>
          </div>
        `;

        container.append(box);
      });

    } catch (err) {
      console.error("Error loading plans:", err);
    }
  }

  loadPlans();
});
</script>
