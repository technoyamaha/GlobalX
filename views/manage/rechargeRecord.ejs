<script>
  let allRechargeData = [];
  function showToast(status, message) {
    const toast = document.getElementById("toast");
    const toastMessage = document.getElementById("toast-message");
    let toastTimeout;

    toastMessage.innerText = message;

    toast.classList.remove("bg-success1", "bg-danger1");
    toast.classList.add(status ? "bg-success1" : "bg-danger1");
    toast.classList.add("show");

    clearTimeout(toastTimeout);
    toastTimeout = setTimeout(() => {
      hideToast();
    }, 3000);
  }

  function hideToast() {
    const toast = document.getElementById("toast");
    toast.classList.remove("show");
  }

  let rechargePage = 1,
    rechargeLimit = 10,
    searchQuery = "";

  const PaymentMethodsMap = {
    upi_gateway: "UPI GATEWAY",
    upi_gatewa: "UPI GATEWAY",
    upi_manual: "UPI Manual",
    usdt_manual: "USDT Manual",
    wow_pay: "WOW Pay",
    usdt: "USDT",
    india_pay: "INDIA PAY",
    zynte_pay: "ZYNTE PAY",
  };

  $(document).on("click", ".confirm-btn", function (e) {
    e.preventDefault();
    let id = $(this).attr("data");

    $.ajax({
      type: "POST",
      url: "/admin/rechargeDuyet",
      data: {
        id: id,
        type: "confirm",
      },
      dataType: "json",
      success: function (response) {
        showToast(true, response.message || "Operation successful!");
        setTimeout(() => {
          location.reload();
        }, 2000);
      },
      error: function (err) {
        console.error(err);
        showToast(false, err.responseJSON?.message || "Operation failed!");
        setTimeout(() => {
          location.reload();
        }, 2000);
      },
    });
  });

  $(document).on("click", ".btn-danger", function (e) {
    e.preventDefault();
    let id = $(this).attr("data");
    $.ajax({
      type: "POST",
      url: "/admin/rechargeDuyet",
      data: {
        id: id,
        type: "delete",
      },
      dataType: "json",
      success: function (response) {
        showToast(true, response.message || "Operation successful!");
        setTimeout(() => {
          location.reload();
        }, 2000);
      },
      error: function (err) {
        console.error(err);
        showToast(false, err.responseJSON?.message || "Operation failed!");
        setTimeout(() => {
          location.reload();
        }, 2000);
      },
    });
  });

  function formatTime(ts = "", addHours = 0) {
    let date = ts ? new Date(Number(ts)) : new Date();
    date.setHours(date.getHours() + addHours);
    const yyyy = date.getFullYear();
    const mm = ("0" + (date.getMonth() + 1)).slice(-2);
    const dd = ("0" + date.getDate()).slice(-2);
    let h = date.getHours() % 12 || 12;
    const ampm = date.getHours() < 12 ? "AM" : "PM";
    const min = ("0" + date.getMinutes()).slice(-2);
    const sec = ("0" + date.getSeconds()).slice(-2);
    return `${yyyy}-${mm}-${dd} ${h}:${min}:${sec} ${ampm}`;
  }

  function renderRecharge(rows) {
    const tbody = $("#table1 tbody");
    if (!rows || rows.length === 0) {
      tbody.html(
        `<tr class="text-center"><td colspan="9">No data...</td></tr>`
      );
      return;
    }

    const html = rows
      .map(
        (data) => `
      <tr class="text-center">
        <td>${data.id}</td>
        <td><b>${data.email ?? ""}</b></td>       
        <td style="min-width:190px;"><b>${PaymentMethodsMap?.[data.type] ?? data.type
          }</b></td>
        <td><b>${data.money}</b></td>
        <td><b>${data.inr_amount}</b></td>
        <td style="min-width:190px;"><b>${data.id_order}</b></td>
        <td style="min-width:190px;"><b>${data.wallet_id}</b></td>
        <td style="min-width:190px;"><b>${data.utr}</b></td>   
        <td style="min-width:190px;"><b>${formatTime(data.time)}</b></td>
        <td>
          <span class="badge badge-${data.status == 1 ? "success" : "danger"}">
            ${data.status == 1
            ? "Success"
            : data.status == 0
              ? "Pending"
              : "Closed"
          }
          </span>
        </td>
        <td class="project-actions text-center" style="min-width: 160px;">
                    <a class="btn btn-success btn-sm confirm-btn" href="javascript:void(0)" data="${data.id
          }"><i class="fa fa-check"></i></a>
            <a class="btn btn-danger btn-sm delete-btn" href="#" data="${data.id
          }"><i class="fas fa-trash"></i></a>
                   
                  </td>
      </tr>
    `
      )
      .join("");

    tbody.html(html);
  }

  function applyClientSearchFilter() {
    let filtered = allRechargeData;

    if (searchQuery) {
      const lowerSearch = searchQuery.toLowerCase();
      filtered = allRechargeData.filter((item) => {
        return (
          String(item.email || "")
            .toLowerCase()
            .includes(lowerSearch) ||
          String(item.type || "")
            .toLowerCase()
            .includes(lowerSearch) ||
          String(item.money || "")
            .toLowerCase()
            .includes(lowerSearch) ||
          String(item.id_order || "")
            .toLowerCase()
            .includes(lowerSearch) ||
          String(item.utr || "")
            .toLowerCase()
            .includes(lowerSearch) ||
          String(formatTime(item.time) || "")
            .toLowerCase()
            .includes(lowerSearch) ||
          (item.status == 1
            ? "success"
            : item.status == 0
              ? "pending"
              : "closed"
          ).includes(lowerSearch)
        );
      });
    }

    renderRecharge(filtered);
  }

  function renderPagination(currentPage, totalPages) {
    const pagination = $("#pagination-controls");
    pagination.empty();

    // Previous button
    pagination.append(`
    <li class="page-item ${currentPage === 1 ? "disabled" : ""}">
      <a class="page-link" href="#" id="previous">Previous</a>
    </li>
  `);

    // Determine pagination window
    const maxButtons = 5;
    let start = Math.max(currentPage - Math.floor(maxButtons / 2), 1);
    let end = start + maxButtons - 1;
    if (end > totalPages) {
      end = totalPages;
      start = Math.max(1, end - maxButtons + 1);
    }

    // Page numbers
    for (let i = start; i <= end; i++) {
      pagination.append(`
      <li class="page-item ${i === currentPage ? "active" : ""}">
        <a class="page-link" href="#" data-page="${i}">${i}</a>
      </li>
    `);
    }

    // Next button
    pagination.append(`
    <li class="page-item ${currentPage === totalPages ? "disabled" : ""}">
      <a class="page-link" href="#" id="next">Next</a>
    </li>
  `);
  }

  // function loadRecharge(page, type = "") {
  //   if (type === "Next") page += 1;
  //   if (type === "Previous") page -= 1;
  //   if (page < 1) return;

  //   $.post(
  //     "/admin/recharge",
  //     {
  //       status: "pending",
  //       page,
  //       limit: rechargeLimit,
  //       search: searchQuery,
  //     },
  //     function (res) {
  //       if (res.status) {
  //         if (page > res.totalRechargesPages) return;

  //         rechargePage = page;
  //         $("#text-page").text(`${page} / ${res.totalRechargesPages}`);

  //         allRechargeData = res.datas || [];
  //         applyClientSearchFilter();

  //         renderPagination(rechargePage, res.totalRechargesPages);

  //         if (res.totalRechargeAmount !== undefined) {
  //           $("#recharge_value").text(res.totalRechargeAmount);
  //         }
  //         //     if (res.totalRecords !== undefined) {
  //         //         if ($("#total_recharge_count").length === 0) {
  //         //             $("#recharge_value").after(`<div id="total_recharge_count" style="font-weight:bold; color:#555; display:inline-block; margin-left:10px;">(${res.totalRecords} records)</div>`);
  //         //         } else {
  //         //             $("#total_recharge_count").text(`(${res.totalRecords} records)`);
  //         //         }
  //         //     }
  //         // } else {
  //         //     $("#table1 tbody").html('<tr><td colspan="9" class="text-center">Error loading data</td></tr>');
  //       }
  //     }
  //   );
  // }


  function loadRecharge(page, type = "") {
  if (type === "Next") page += 1;
  if (type === "Previous") page -= 1;
  if (page < 1) return;

  $.post(
    "/admin/recharge",
    {
      status: "pending",
      page,
      limit: rechargeLimit,
      search: searchQuery,
    },
    function (res) {
      if (!res.status) {
        renderRecharge([]); // clear table
        return;
      }

      rechargePage = page;


      renderRecharge(res.datas || []);


      const totalPages = res.totalRechargesPages || 0;
      renderPagination(rechargePage, totalPages);


      if (!res.datas || res.datas.length === 0) {
        $("#table1 tbody").html(
          `<tr class="text-center"><td colspan="10">No data...</td></tr>`
        );
      }
    }
  );
}


  $(document).ready(function () {
    loadRecharge(rechargePage);

    // Pagination buttons
    $("#next").click((e) => {
      e.preventDefault();
      loadRecharge(rechargePage, "Next");
    });
    $("#previous").click((e) => {
      e.preventDefault();
      if (rechargePage > 1) loadRecharge(rechargePage, "Previous");
    });

    // // Search with debounce
    // let debounceTimer;
    // $("#search").on("keyup", function () {
    //     clearTimeout(debounceTimer);
    //     debounceTimer = setTimeout(() => {
    //         searchQuery = $(this).val().trim();
    //         applyClientSearchFilter();
    //     }, 400);
    // });

    let debounceTimer;
   $("#search").on("keyup", function () {
  clearTimeout(debounceTimer);
  debounceTimer = setTimeout(() => {
    searchQuery = $(this).val().trim();
    rechargePage = 1;
    loadRecharge(rechargePage);
  }, 400);
});

    $(document).on(
      "click",
      "#pagination-controls .page-link[data-page]",
      function (e) {
        e.preventDefault();
        const targetPage = parseInt($(this).data("page"));
        if (!isNaN(targetPage)) {
          loadRecharge(targetPage);
        }
      }
    );

    $(document).on("click", "#previous", function (e) {
      e.preventDefault();
      if (rechargePage > 1) {
        loadRecharge(rechargePage - 1);
      }
    });

    $(document).on("click", "#next", function (e) {
      e.preventDefault();
      loadRecharge(rechargePage + 1);
    });

    $("#jump-go").click(function () {
      const targetPage = parseInt($("#jump-to-page").val());
      if (!isNaN(targetPage) && targetPage > 0) {
        loadRecharge(targetPage);
      }
    });
  });
</script>

<script>
  let startDatefor = moment.tz("Asia/Kolkata").startOf("day");
  let delayedDate = startDatefor.clone();
  let startDate = delayedDate.valueOf();
  let enddate = startDate + 86399000;
  let total_recharge = $("#recharge_value");

  $(document).ready(function () {
    $("#date_picker").val(moment(startDate).format("YYYY-MM-DD"));
    getTotalRecharge(startDate, enddate);
  });
  $("#date_picker").on("change", function () {
    startDate = moment(this.value).valueOf();
    enddate = startDate + 86399000;
    getTotalRecharge(startDate, enddate);
  });
  const getTotalRecharge = async (first, last) => {
    const response = await fetch(
      `/admin/totalrecharge?start=${first}&end=${last}`
    );
    const data = await response.json();
    if (data.total_value == null) {
      console.log("isnull");
      total_recharge.text(0);
    } else {
      console.log(data.total_value);
      total_recharge.text(data.total_value);
    }
  };
  getTotalRecharge(startDate, enddate);

  $("#sidebarToggle").on("click", function () {
    $("body").toggleClass("sidebar-collapsed");
  });
</script>