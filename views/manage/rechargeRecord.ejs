    }

    .total_recharge {
      justify-content: center;
      font-size: 1rem;
    }

    #date_picker {
      max-width: 100%;
      margin: 0 auto;
    }

    table#table1 tbody td {
      font-size: 0.85rem;
      padding: 8px 6px;
    }
