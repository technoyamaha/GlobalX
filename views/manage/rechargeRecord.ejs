    font-size: 1rem;
  }

  #date_picker {
    padding: 8px 12px;
    border-radius: 6px;
    border: 1px solid #ccc;
    font-size: 1rem;
    transition: border-color 0.2s ease-in-out;
    cursor: pointer;
  }

  #date_picker:focus {
    outline: none;
    border-color: #007bff;
    box-shadow: 0 0 5px rgba(0, 123, 255, 0.5);
  }

  .card {
    border: none;
    border-radius: 8px;
    box-shadow: 0 2px 8px rgb(0 0 0 / 0.1);
  }

  .card-header {
    background-color: #007bff;
    color: #fff;
    border-top-left-radius: 8px;
    border-top-right-radius: 8px;
    padding: 12px 20px;
    font-weight: 600;
    font-size: 1.25rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .card-tools button {
    color: #fff;
    font-size: 1.1rem;
    transition: color 0.3s;
  }

  .card-tools button:hover {
    color: #d1e7ff;
  }

  table#table1 {
    width: 100%;
    border-collapse: separate;
    border-spacing: 0 10px;
  }

  table#table1 thead th {
    background-color: #f1f3f5;
    color: #495057;
    font-weight: 600;
    text-align: center;
    padding: 12px;
    border-radius: 6px;
  }

  table#table1 tbody tr {
    background-color: #fff;
    box-shadow: 0 2px 5px rgb(0 0 0 / 0.05);
    transition: background-color 0.2s ease;
  }

  table#table1 tbody tr:hover {
    background-color: #f8f9fa;
  }

  table#table1 tbody td {
    padding: 10px 12px;
    text-align: center;
    vertical-align: middle;
    font-size: 0.95rem;
  }

  .badge-success {
    background-color: #28a745;
    color: white;
    padding: 5px 12px;
    border-radius: 12px;
    font-size: 0.85rem;
  }

  .badge-danger {
    background-color: #dc3545;
    color: white;
    padding: 5px 12px;
    border-radius: 12px;
    font-size: 0.85rem;
  }

  nav.pagination {
    margin-top: 20px;
  }

  ul.pagination {
    display: flex;
    justify-content: center;
    list-style: none;
    padding-left: 0;
  }

  ul.pagination li.page-item {
    margin: 0 5px;
  }

  ul.pagination li.page-item a.page-link {
    color: #101010;
    border: 1px solid #dee2e6;
    padding: 7px 14px;
    border-radius: 5px;
    font-weight: 500;
    cursor: pointer;
    user-select: none;
    transition: background-color 0.2s ease, color 0.2s ease;
  }

  ul.pagination li.page-item a.page-link:hover {
    background-color: #007bff;
    color: white;
  }

  ul.pagination li.page-item a.page-link.active {
    background-color: #007bff;
    color: white;
    border-color: #007bff;
  }

  ul.pagination li.page-item.disabled a.page-link {
    color: #6c757d;
    pointer-events: none;
    cursor: default;
    background-color: #fff;
  }

  #toast {
    visibility: hidden;
    min-width: auto;
    background-color: #333;
    color: #fff;
    text-align: center;
    border-radius: 4px;
    padding: 16px 20px;
    position: fixed;
    z-index: 9999;
    top: 20px;
    right: 20px;
    transform: translateY(-100%);
    font-size: 16px;
    transition: all 0.4s ease-in-out;
    opacity: 0;
    display: flex;
    align-items: center;
    gap: 10px;
  }

  #toast.show {
    visibility: visible;
    opacity: 1;
    transform: translateY(0%);
  }

  #toast span#toast-close {
    font-size: 20px;
    cursor: pointer;
    opacity: 0.7;
  }
  .table-striped>tbody>tr:nth-of-type(odd)>* {
    background: #1E3A6E;
    color: #fff;
}

  @media (max-width: 768px) {
    .content-wrapper {
      margin-left: 0;
