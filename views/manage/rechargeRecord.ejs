<style>
  body {
    font-family: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif;  
  }
    body.bg-light {
    background: #001a3d !important;
    color: #fff;
}

  .content-wrapper {
    margin-left: 250px; 
    background: rgba(255, 255, 255, 0.08);
    border-radius: 8px;
    box-shadow: 0 2px 8px rgb(0 0 0 / 0.1);
    padding: 20px;
  }

  h1,
  h3 {
    color: #ffffff;
  }

  .form-group {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    align-items: center;
    gap: 15px;
    margin-bottom: 25px;
  }

  #search {
    flex-grow: 1;
    min-width: 250px;
    max-width: 400px;
    padding: 10px 15px;
    border-radius: 6px;
