<link rel="stylesheet"
    href="https://fonts.googleapis.com/css?family=Source+Sans+Pro:300,400,600,700&display=fallback" />

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/4.7.0/css/font-awesome.min.css" />


<link href="//cdn.jsdelivr.net/npm/@sweetalert2/theme-dark@4/dark.css" rel="stylesheet" />


<script src="https://code.jquery.com/jquery-3.6.4.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/lodash@4.17.21/lodash.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

<script src="https://cdnjs.cloudflare.com/ajax/libs/moment.js/2.29.1/moment.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/moment-timezone/0.5.34/moment-timezone-with-data.min.js"></script>


<div class="main px-lg-4 px-md-4">
    <%- include('../partials/header') %>
        <div class="body d-flex py-3">
            <div class="container-xxl">
                <div class="row align-items-center">
                    <div class="border-0 mb-4">
                        <div
                            class="card-header py-3 no-bg bg-transparent d-flex align-items-center px-0 justify-content-between border-bottom flex-wrap">
                            <h3 class="fw-bold mb-0">Withdrawal History</h3>
                        </div>
                    </div>
                </div>
                <div class="row">
                    <div class="col-12">
                        <div class="card mb-3">
                            <div class="card-body">
                                <div class="table-responsive depost-table-main-outer-wrapper">
                                    <table class="table table-hover">
                                        <thead>
                                            <tr>
                                                <th scope="col">#Sr No</th>
                                                <th scope="col">Txn Date</th>
                                                <th scope="col">Txn#</th>
                                                <th scope="col">Amount</th>
                                                <!-- <th scope="col" class="text-center">Amount Transferred to P2P</th> -->
                                                <!-- <th scope="col" class="text-center">Fees Deducted</th> -->
                                                <th scope="col" class="text-center">Amount Received</th>
                                                <th scope="col" class="text-center">Status</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <tr id="loadingRow">
                                                <td colspan="7" class="text-center">Loading withdrawal history...</td>
                                            </tr>
                                        </tbody>
                                    </table>
                                </div>
                                <div class="row align-items-center">
                                    <div class="col ps-2">
                                        <div class="row align-items-center mx-0 mb-3">
                                            <div class="col-12 footable-paging-external footable-paging-right d-flex justify-content-center"
                                                id="footable-pagination">
                                                <div class="footable-pagination-wrapper">
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
</div>



<script>
    $(document).ready(function () {

        const tbody = $("table tbody");

        // Show loading state
        tbody.html('<tr id="loadingRow"><td colspan="7" class="text-center">Loading withdrawal history...</td></tr>');


        $.ajax({
            url: "/api/withdraw-history",
            method: "GET",
            contentType: "application/json",
            success: function (res) {
                if (res.status === 200 && Array.isArray(res.data)) {
                    const tbody = $("table tbody");
                    tbody.empty();

                    if (res.data.length === 0) {
                        tbody.append('<tr><td colspan="7" class="text-center">No withdrawals found.</td></tr>');
                    } else {
                        res.data.forEach((item, index) => {
                            const txnDate = new Date(parseInt(item.created_at)).toLocaleDateString();
                            const html = `                            
              <tr>
                <td>${index + 1}</td>
                <td>${txnDate}</td>
                <td>${item.wallet || '-'}</td>
                <td>${parseFloat(item.amount).toFixed(2)}</td>
                   <td>0.00</td>
                <td>${item.fee_deduct}</td>
                <td>${item.amount_received}</td>
                <td>${item.status_text}</td>
           
              </tr>
            `;
                            tbody.append(html);
                        });
                    }
                }
            },
            error: function (xhr, status, error) {
                let msg = xhr.responseJSON?.message || "Failed to load withdrawal history!";
                showToast(false, msg);
                console.error(" Error:", msg);
            }
        });
    });
</script>