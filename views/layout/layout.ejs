  <style>
    #toast {
      visibility: hidden;
      min-width: auto;
      background-color: #333;
      color: #fff;
      text-align: center;
      border-radius: 4px;
      padding: 16px 20px;
      position: fixed;
      z-index: 9999;
      bottom: unset;
      left: unset;
      top: 20px;
      right: 20px;
      transform: translatey(-100%);
      font-size: 16px;
      transition: visibility 0s, opacity 0.5s ease-in-out;
      transition: all .4s cubic-bezier(.215, .61, .355, 1);
      opacity: 0;
      display: flex;
      align-items: center;
      gap: 10px;
    }

    #toast span#toast-close {
      font-size: 20px;
      line-height: 20px;
      display: flex;
      align-items: center;
      position: relative;
      top: -1px;
      cursor: pointer;
      opacity: 0.7;
    }

    .bg-success1 {
      background-color: #26c714 !important;
    }

    .bg-danger1 {
      background-color: red !important;
    }

    #toast.show {
      visibility: visible;
      opacity: 1;
      transform: translatey(0%);
    }

    .float {
      position: fixed;
      bottom: 4rem;
      right: .4rem;
      touch-action: none;
      z-index: 999;
    }
  </style>

  <script src="https://cdn.jsdelivr.net/npm/moment@2.29.4/moment.min.js"></script>
</head>

<body class="<%= typeof bodyClass !== 'undefined' && bodyClass && bodyClass.trim() !== '' 
  ? bodyClass 
  : 'hold-transition sidebar-mini layout-fixed' %>">

  <% if (bodyClass !=='main-landing-custm-page' ) { %>
    <div id="cryptoon-layout" class="theme-orange">
      <% } %>

        <!-- Toast -->
        <div id="toast">
          <span id="toast-message"></span>
          <span id="toast-close" onclick="hideToast()"> ×</span>
        </div>

     
        <% if (bodyClass !=='main-landing-custm-page' ) { %>
          <%- include('../nav/nav') %>
            <% } %>

              <!-- Page Content -->
              <%- body %>

                <% if (bodyClass !=='main-landing-custm-page' ) { %>
    </div>
    <% } %>

</body>

<script>
  document.addEventListener("DOMContentLoaded", function () {
    const signoutBtn = document.getElementById("signoutBtn");
    if (signoutBtn) {
      signoutBtn.addEventListener("click", function (e) {
        e.preventDefault();
        document.cookie = "token=; Max-Age=0; path=/";
        document.cookie = "auth=; Max-Age=0; path=/";
        localStorage.clear();
        window.location.href = "/login";
      });
    }
  });

  document.addEventListener("DOMContentLoaded", function () {
    const sidebar = document.querySelector(".sidebar");
    const closeBtn = document.querySelector(".sidebar-mini-btn");
    if (closeBtn && sidebar) {
      closeBtn.addEventListener("click", function () {
        sidebar.classList.remove("open");
      });
    }
  });

  function showToast(status, message) {
    const toast = document.getElementById("toast");
    const toastMessage = document.getElementById("toast-message");
    let toastTimeout;
    toastMessage.innerText = message;

    toast.classList.remove("bg-success1", "bg-danger1");
    toast.classList.add(status ? "bg-success1" : "bg-danger1");
    toast.classList.add("show");

    clearTimeout(toastTimeout);
    toastTimeout = setTimeout(() => {
      hideToast();
    }, 3000);
  }

  function hideToast() {
    const toast = document.getElementById("toast");
    toast.classList.remove("show");
  }
</script>

</html>