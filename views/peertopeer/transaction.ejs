<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

<script>
    $(document).ready(function () {
        function loadTransactions(query = "") {
            $.ajax({
                url: "/api/p2p/transferHistory",
                type: "GET",
                data: { search: query },
                success: function (response) {
                    if (response.status) {
                        const totalCredit = parseFloat(response.totalCredit) || 0;
                        const totalDebit = parseFloat(response.totalDebit) || 0;

                        $(".total-credit").text(totalCredit.toFixed(4) + " USD");
                        $(".total-debit").text(totalDebit.toFixed(4) + " USD");

                        const tbody = $("#transactions-table-body");
                        tbody.empty();

                        if (response.transactions.length === 0) {
                            tbody.append(`<tr><td colspan="5" class="text-center">No transactions found</td></tr>`);
                            return;
                        }

                        response.transactions.forEach((tx, index) => {
                            tbody.append(`
                          <tr>
                            <td>${index + 1}</td>
                            <td>${tx.counterpartyName || tx.counterparty}</td>
                            <td>${tx.money} USD</td>
                            <td>${tx.type}</td>
                            <td>${tx.datetime}</td>
                          </tr>
                        `);
                        });
                    }
                },
                error: function (xhr) {
                    console.error("Failed to load transactions:", xhr);
                },
            });
        }

        loadTransactions();

        // Search on input with debounce
        let searchTimer;
        $("#searchBox").on("input", function () {
            clearTimeout(searchTimer);
            const query = $(this).val();
            searchTimer = setTimeout(() => {
                loadTransactions(query);
            }, 300);
        });
    });
</script>