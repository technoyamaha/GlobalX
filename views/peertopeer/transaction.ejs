                        </div>
                        <div data-v-9283bae4="" class="row align-items-center mt-3">
                            <div data-v-9283bae4="" class="col-12 col-md-6 col-lg-4 mb-2">
                                <div data-v-9283bae4="" class="input-group">
                                    <input type="text" id="searchBox" class="form-control rounded-pill-left big-font"
                                        placeholder="Search..."><span
                                        class="input-group-text text-theme rounded-pill-right"><i
                                            class="bi bi-search"></i></span>
                                </div>
                            </div>
                            <div data-v-9283bae4="" class="col-12 col-md-6 col-lg-4 mb-2">
                                <div data-v-9283bae4="" class="card bg-lightgreen">
                                    <div data-v-9283bae4="" class="card-header">
                                        <h6 data-v-9283bae4="">Total P2P Credit</h6>
                                    </div>
                                    <div data-v-9283bae4="" class="card-body">
                                        <h4 data-v-9283bae4="" class="total-credit"></h4>
                                    </div>
                                </div>
                            </div>
                            <div data-v-9283bae4="" class="col-12 col-md-6 col-lg-4 mb-2">
                                <div data-v-9283bae4="" class="card bg-lightyellow">
                                    <div data-v-9283bae4="" class="card-header">
                                        <h6 data-v-9283bae4="">Total P2P Transfer</h6>
                                    </div>
                                    <div data-v-9283bae4="" class="card-body">
                                        <h4 data-v-9283bae4="" class="total-debit"></h4>
                                    </div>
                                </div>
