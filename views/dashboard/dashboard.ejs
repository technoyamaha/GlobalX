    color: #fff;
    font-size: 14px;
    font-weight: 600;
    box-shadow: 0 12px 30px rgba(0, 0, 0, 0.35);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    animation: gxSlideIn 0.25s ease;
  }

  .gx-toast-success {
    background: linear-gradient(135deg, #16a34a, #22c55e);
  }

  .gx-toast-error {
    background: linear-gradient(135deg, #dc2626, #ef4444);
  }

  .gx-toast-close {
    cursor: pointer;
    font-size: 20px;
    line-height: 1;
    opacity: 0.9;
  }

  @keyframes gxSlideIn {
    from {
      transform: translateX(120%);
      opacity: 0;
    }

    to {
      transform: translateX(0);
      opacity: 1;
    }
  }
</style>


