<script>

$.ajax({
  url: '/api/info',
  method: 'GET',
  dataType: 'json',
  cache: false,
  success: function(res) {
    if (!res || !res.status || !res.user) {
      console.warn('/api/info returned unexpected', res);
      return;
    }

    const user = res.user;
    const lastLogin = res.last_login || (Array.isArray(res.last_5_login) ? res.last_5_login[0] : null);

    function fmtMoney(n) {
      const num = Number(n) || 0;
      return '$ ' + num.toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 });
    }

    function fmtLastLogin(l) {
      if (!l) return '—';
      const raw = l.today || l.login_at || l.time || l.created_at || l.date || l.datetime || null;
      if (!raw) {
        const v = Object.values(l)[0];
        if (!v) return '—';
        return String(v);
      }
      let dt = /^\d+$/.test(String(raw)) ? new Date(Number(raw)) : new Date(raw);
      if (isNaN(dt.getTime())) return String(raw);
      const d = dt.toLocaleDateString(undefined, { year: 'numeric', month: 'short', day: '2-digit' });
      const t = dt.toLocaleTimeString(undefined, { hour: '2-digit', minute: '2-digit' });
      return `${d} · ${t}`;
    }

    if (user.withdrawable_balance !== undefined && user.withdrawable_balance !== null) {
      $('.withdrawBalance').text(fmtMoney(user.withdrawable_balance));
    } 
    if (user.money ) $('.depositedMoney').text(fmtMoney(user.money));
    
    if (res.totalWithdrawAmount) $('.totalWithdraw').text(fmtMoney(res.totalWithdrawAmount));
    $('#lastActivity').text(fmtLastLogin(lastLogin));

  },
  error: function(xhr) {
    if (xhr && xhr.status === 401) {
      window.location.href = '/login';
      return;
    }
    console.error('/api/info error', xhr && xhr.responseText);
  }
});



$.ajax({
  url: '/api/mining-income', 
  method: 'GET',
  dataType: 'json',
  cache: false,
  success: function(res) {
    if (!res || !res.status) {
      console.warn('/mining-income returned unexpected', res);
      return;
    }

    // totalInvested is numeric (server provides it)
    var totalInvested = Number(res.totalInvested || 0);
    var totalInvestments = Number(res.totalInvestments || 0);

    function fmtMoney(n) {
      var num = Number(n) || 0;
      return '$ ' + num.toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 });
    }

    // update only the element(s) you have
    if ($('.investedAmount').length) {
      $('.investedAmount').text(fmtMoney(totalInvested));
    }
    
    if ($('.totalInvestments').length) {
      $('.totalInvestments').text(totalInvestments);
    }
  },
  error: function(xhr) {
    if (xhr && xhr.status === 401) { window.location.href = '/login'; return; }
    console.error('/mining-income error', xhr && xhr.responseText);
  }
});



</script>
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

<script>
$(document).ready(function () {

  // =========================
  // 👉 PAGE SWITCH FUNCTION
  // =========================
  window.showPage = function(pageId) {

    // hide all pages
    $(".page").hide();

    // show selected page
    $("#" + pageId).show();

    // remove active from all
    $("ul li").removeClass("active");

    // set active based on onclick
    $("li[onclick*=\"" + pageId + "\"]").addClass("active");
  };

  // =========================
  // 👉 Normal menu (no submenu)
  // =========================
  $("ul > li").not(":has(ul)").click(function (e) {
    e.stopPropagation();

    let onclickAttr = $(this).attr("onclick");

    if (onclickAttr) {
      let match = onclickAttr.match(/showPage\('(.+?)'\)/);
      if (match) {
        showPage(match[1]);
      }
    }

    // active toggle
    if ($(this).hasClass("active")) {
      $(this).removeClass("active");
    } else {
      $("ul li").removeClass("active");
      $(this).addClass("active");
    }
  });

  // =========================
  // 👉 Parent menu (has submenu)
  // =========================
  $("ul > li:has(ul)").click(function (e) {
    e.stopPropagation();

    let submenu = $(this).children(".submenu");

    // toggle submenu
    submenu.slideToggle(200);

    // toggle active
    $(this).toggleClass("active");
  });

  // =========================
  // 👉 Submenu items
  // =========================
  $(".submenu li").click(function (e) {
    e.stopPropagation();

    let onclickAttr = $(this).attr("onclick");

    if (onclickAttr) {
      let match = onclickAttr.match(/showPage\('(.+?)'\)/);
      if (match) {
        showPage(match[1]);
      }
    }

    // remove all active
    $("ul li").removeClass("active");

    // active on clicked child
    $(this).addClass("active");

    // active on parent
    $(this).closest("li:has(ul)").addClass("active");
  });

  // =========================
  // 👉 Default active page
  // =========================
  $("ul > li:first").addClass("active");

  // optional default page load
  let first = $("ul > li:first").attr("onclick");
  if (first) {
    let match = first.match(/showPage\('(.+?)'\)/);
    if (match) {
      showPage(match[1]);
    }
  }

});
</script>
</script>

