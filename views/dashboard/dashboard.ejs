<script>
  let currentUser = null;

  async function loadUserInfo() {
    try {
      const res = await fetch("/api/info", {
        credentials: "include"
      });

      const data = await res.json();

      if (!data.status) {
        showToast(false, "Failed to load user info");
        return;
      }

      const user = data.user;
      currentUser = user;


      document.getElementById("userName").innerText = user.full_name || "User";


      document.getElementById("userId").innerText = "@" + user.id_user;

    } catch (err) {
      console.error(err);
      showToast(false, "Error loading dashboard");
    }
  }

  async function loadTeamStats() {
    try {
      const res = await fetch("/api/team/stats", {
        credentials: "include"
      });

      const data = await res.json();

      if (!data.status) {
        showToast(false, "Failed to load team stats");
        return;
      }

      const stats = data.data;

      document.getElementById("totalTeam").innerText = stats.totalTeam || 0;

      document.getElementById("activeDirect").innerText =
        `${stats.activeDirect || 0}/${stats.directTeam || 0}`;

      document.getElementById("activeTeam").innerText =
        stats.activeTeam || 0;

    } catch (err) {
      console.error(err);
      showToast(false, "Error loading team stats");
    }
  }


  document.addEventListener("click", async function (e) {
    if (e.target.closest("#copyRefBtn")) {
      if (!currentUser) {
        showToast(false, "User not loaded");
        return;
      }

      const referralLink = `${window.location.origin}/register?ref=${currentUser.code}`;

      try {
        await navigator.clipboard.writeText(referralLink);
        showToast(true, "Referral link copied!");
      } catch (err) {
        console.error(err);
        showToast(false, "Copy failed");
      }
    }
  });

  // INIT
  loadUserInfo();
  loadTeamStats();

</script>



<script>
  $(document).ready(function () {

    // =========================
    // 👉 PAGE SWITCH FUNCTION
    // =========================
    window.showPage = function (pageId) {

      // hide all pages
      $(".page").hide();

      // show selected page
      $("#" + pageId).show();

      // remove active from all
      $("ul li").removeClass("active");

      // set active based on onclick
      $("li[onclick*=\"" + pageId + "\"]").addClass("active");
    };

    // =========================
    // 👉 Normal menu (no submenu)
    // =========================
    $("ul > li").not(":has(ul)").click(function (e) {
      e.stopPropagation();

      let onclickAttr = $(this).attr("onclick");

      if (onclickAttr) {
        let match = onclickAttr.match(/showPage\('(.+?)'\)/);
        if (match) {
          showPage(match[1]);
        }
      }

      // active toggle
      if ($(this).hasClass("active")) {
        $(this).removeClass("active");
      } else {
        $("ul li").removeClass("active");
        $(this).addClass("active");
      }
    });

    // =========================
    // 👉 Parent menu (has submenu)
    // =========================
    $("ul > li:has(ul)").click(function (e) {
      e.stopPropagation();

      let submenu = $(this).children(".submenu");

      // toggle submenu
      submenu.slideToggle(200);

      // toggle active
      $(this).toggleClass("active");
    });

    // =========================
    // 👉 Submenu items
    // =========================
    $(".submenu li").click(function (e) {
      e.stopPropagation();

      let onclickAttr = $(this).attr("onclick");

      if (onclickAttr) {
        let match = onclickAttr.match(/showPage\('(.+?)'\)/);
        if (match) {
          showPage(match[1]);
        }
      }

      // remove all active
      $("ul li").removeClass("active");

      // active on clicked child
      $(this).addClass("active");

      // active on parent
      $(this).closest("li:has(ul)").addClass("active");
    });

    // =========================
    // 👉 Default active page
    // =========================
    $("ul > li:first").addClass("active");

    // optional default page load
    let first = $("ul > li:first").attr("onclick");
    if (first) {
      let match = first.match(/showPage\('(.+?)'\)/);
      if (match) {
        showPage(match[1]);
      }
    }

  });



  function showToast(status, message) {
    const container = document.getElementById("gxToastContainer");
    if (!container) return console.error("Toast container not found");

    container.innerHTML = "";

    const toast = document.createElement("div");
    toast.className = `gx-toast ${status ? "gx-toast-success" : "gx-toast-error"}`;
    toast.innerHTML = `
      <span>${message}</span>
      <span class="gx-toast-close">&times;</span>
    `;

    container.appendChild(toast);

    toast.querySelector(".gx-toast-close").addEventListener("click", function () {
      toast.remove();
    });

    setTimeout(function () {
      toast.remove();
    }, 3500);
  }




</script>
</script>