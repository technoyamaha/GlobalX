<style>
    .sidebar-mini .sidebar {
        background: #1E3A6E;

    }

    .sidebar {
        width: 250px;
        transition: width 0.3s ease;
        height: 100vh;
        background: #343a40;
        color: #fff;
        position: fixed;
        top: 0;
        left: 0;
        overflow-y: auto;
        padding-top: 20px;
        z-index: 1000;

        display: flex;
        flex-direction: column;
    }

    .sidebar-content {
        flex: 1;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        /* Pushes the button to the bottom */
    }


    .sidebar.collapsed {
        width: 70px;
    }

    .sidebar .user-panel {
        display: flex;
        align-items: center;
        padding: 10px 15px;
        transition: all 0.3s ease;
    }

    .sidebar.collapsed .user-panel .info {
        display: none;
    }

    .sidebar .user-panel .image img {
        width: 40px;
        height: 40px;
        border-radius: 50%;
    }

    .sidebar .nav-link {
        /* color: #c2c7d0; */
        color: #e6e6e6;
        padding: 10px 15px;
        display: flex;
        align-items: center;
        transition: all 0.3s ease;
        white-space: nowrap;
    }

    .sidebar .nav-link:hover {
        /* background: #495057; */
        background: rgba(255, 255, 255, 0.08);
        color: #fff;
    }

    .sidebar .nav-link i {
        margin-right: 10px;
        min-width: 20px;
        text-align: center;
    }

    .sidebar.collapsed .nav-link span {
        display: none;
    }

    .sidebar.collapsed .nav-link {
        justify-content: center;
        padding: 10px 0;
    }

    .content-wrapper {
        margin-left: 250px;
        transition: margin-left 0.3s ease;
    }

    .main-content.expanded {
        margin-left: 70px;
    }

    .sidebar-mini-btn {
        width: 100%;
        text-align: center;
        padding: 10px;
        border: none;
        background: none;
        color: #ccc;
        cursor: pointer;
        font-size: 20px;
        transition: all 0.3s ease;
        border-top: 1px solid rgba(255, 255, 255, 0.08);
        border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    }

    .sidebar-mini-btn:hover {
        background: rgba(255, 255, 255, 0.08);
        color: white;
    }

    .sidebar.collapsed .sidebar-mini-btn i {
        transform: rotate(180deg);
    }

    .sidebar-mini-btn {
        width: 100%;
        text-align: center;
        padding: 10px;
        border: none;
        background: none;
        color: #ccc;
        cursor: pointer;
        font-size: 20px;
        transition: all 0.3s ease;
        border-top: 1px solid #495057;
        border-bottom: 1px solid #495057;
    }

    /* Add this to respond to sidebar collapse on body */

    body.sidebar-collapsed .sidebar {
        width: 70px !important;
    }

    body.sidebar-collapsed .content-wrapper {
        margin-left: 70px !important;
        transition: margin-left 0.3s ease !important;
    }

    body .content-wrapper {
        margin-left: 250px !important;
        transition: margin-left 0.3s ease !important;
    }



    @media (max-width: 768px) {
        .sidebar {
            width: 250px;
            transform: translateX(0);
        }

        .sidebar.collapsed {
            transform: translateX(-100%);
        }

        .content-wrapper {
            margin-left: 0;
        }

        .main-content.expanded {
            margin-left: 0;
        }
    }
</style>


<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.0/font/bootstrap-icons.css" />

<aside class="sidebar">
    <div class="user-panel">
        <div class="image">
            <img src="https://ui-avatars.com/api/?name=Admin&background=0D8ABC&color=fff&size=64" alt="Admin User" />
        </div>
        <div class="info">Admin | GlobalX</div>
    </div>


    <div class="sidebar-content">
        <ul class="nav flex-column">
            <li class="nav-item">
                <a href="/admin/dashboard" class="nav-link">
                    <i class="fas fa-tachometer-alt"></i> <span>Dashboard</span>
                </a>
            </li>
            <li class="nav-item">
                <a href="/admin/membersList" class="nav-link">
                    <i class="fa fa-user-circle"></i> <span>Members</span>
                </a>
            </li>

            <li class="nav-item">
                <a href="/admin/settings" class="nav-link">
                    <i class="fa fa-cog"></i> <span>Settings</span>
                </a>
            </li>
            <li class="nav-item">
                <a href="/admin/roi" class="nav-link">
                    <i class="fa fa-chart-line"></i> <span>ROI Dashboard</span>
                </a>
            </li>

            <li class="nav-item">
                <a href="/admin/browseRecharge" class="nav-link">
                    <i class="fa fa-search-dollar"></i> <span>Browse Recharge</span>
                </a>
            </li>
            <li class="nav-item">
                <a href="/admin/rechargeRecord" class="nav-link">
                    <i class="fa fa-file-invoice-dollar"></i> <span>Deposit Record</span>
                </a>
            </li>
            <li class="nav-item">
                <a href="/admin/withdrawalHistoryRecord" class="nav-link">
                    <i class="fa fa-history"></i> <span>Browse Withdrawal</span>
                </a>
            </li>
            <li class="nav-item">
                <a href="/admin/withdrawalRecord" class="nav-link">
                    <i class="fa fa-hand-holding-usd"></i> <span>Withdrawal Record</span>
                </a>
            </li>
        </ul>
        <button class="sidebar-mini-btn" type="button" id="toggleSidebar">
            <i class="bi bi-chevron-left" id="sidebarToggleIcon"></i>
        </button>
    </div>

</aside>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        const toggleButton = document.getElementById("toggleSidebar");
        const toggleIcon = document.getElementById("sidebarToggleIcon");

        toggleButton.addEventListener("click", () => {
            const body = document.body;
            const sidebar = document.querySelector(".sidebar");

            body.classList.toggle("sidebar-collapsed");
            sidebar.classList.toggle("collapsed");

            // Toggle icon direction
            if (sidebar.classList.contains("collapsed")) {
                toggleIcon.classList.remove("bi-chevron-left");
                toggleIcon.classList.add("bi-chevron-right");
            } else {
                toggleIcon.classList.remove("bi-chevron-right");
                toggleIcon.classList.add("bi-chevron-left");
            }
        });
    });
</script>