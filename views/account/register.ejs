  <div id="gxToastContainer"></div>
  <style>
    #gxToastContainer {
      position: fixed;
      top: 24px;
      right: 24px;
      z-index: 999999;
      display: flex;
      flex-direction: column;
      gap: 12px;
    }

    .gx-toast {
      min-width: 280px;
      max-width: 360px;
      padding: 14px 16px;
      border-radius: 12px;
      color: #fff;
      font-size: 14px;
      font-weight: 600;
      box-shadow: 0 12px 30px rgba(0, 0, 0, 0.35);
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      animation: gxSlideIn 0.25s ease;
    }

    .gx-toast-success {
      background: linear-gradient(135deg, #16a34a, #22c55e);
    }

    .gx-toast-error {
      background: linear-gradient(135deg, #dc2626, #ef4444);
    }

    .gx-toast-close {
      cursor: pointer;
      font-size: 20px;
      line-height: 1;
      opacity: 0.9;
    }

    @keyframes gxSlideIn {
      from {
        transform: translateX(120%);
        opacity: 0;
      }

      to {
        transform: translateX(0);
        opacity: 1;
      }
    }
  </style>


  <script>
    const params = new URLSearchParams(window.location.search);
    const referralCode =
      params.get("ref") ||
      params.get("code") ||
      params.get("invite") ||
      params.get("sponsorCode");

    if (referralCode) {
      const sponsorInput = document.getElementById("sponsorCode");

      if (sponsorInput) {
        sponsorInput.value = referralCode;        
        sponsorInput.readOnly = true;
      }
    }

    let otpSent = false;
    let selectedDialCode = "";

    function showToast(status, message) {
      const container = document.getElementById("gxToastContainer");
      if (!container) return console.error("Toast container not found");

      container.innerHTML = "";

      const toast = document.createElement("div");
      toast.className = `gx-toast ${status ? "gx-toast-success" : "gx-toast-error"}`;
      toast.innerHTML = `
      <span>${message}</span>
      <span class="gx-toast-close">&times;</span>
    `;

      container.appendChild(toast);

      toast.querySelector(".gx-toast-close").addEventListener("click", function () {
        toast.remove();
      });

      setTimeout(function () {
        toast.remove();
      }, 3500);
    }

    const phoneInput = document.getElementById("phone");
    let selectedCountry = "";

    const selectedBox = document.getElementById("selectedCountryBox");
    const optionsContainer = document.getElementById("countryOptions");
    const countrySearch = document.getElementById("countrySearch");
    const countryList = document.getElementById("countryList");

    let allCountries = [];

    const countryCodeHint = document.getElementById("countryCodeHint");

    document.querySelectorAll(".input-icon-eye").forEach((eyeWrapper) => {
      eyeWrapper.style.cursor = "pointer";

      eyeWrapper.addEventListener("click", function () {
        const input = this.parentElement.querySelector("input");
        const icon = this.querySelector("svg");
        if (!input || !icon) return;

        if (input.type === "password") {
          input.type = "text";
          icon.innerHTML = `
          <path d="M17.94 17.94A10.94 10.94 0 0 1 12 19C7 19 2.73 15.11 1 12c.73-1.31 1.71-2.61 2.92-3.79M9.88 9.88A3 3 0 0 0 12 15a3 3 0 0 0 2.12-.88M1 1l22 22"></path>
          <path d="M10.58 5.09A10.94 10.94 0 0 1 12 5c5 0 9.27 3.89 11 7-1 1.73-2.45 3.34-4.22 4.54"></path>
        `;
        } else {
          input.type = "password";
          icon.innerHTML = `
          <path d="M2.062 12.348a1 1 0 0 1 0-.696 10.75 10.75 0 0 1 19.876 0 1 1 0 0 1 0 .696 10.75 10.75 0 0 1-19.876 0"></path>
          <circle cx="12" cy="12" r="3"></circle>
        `;
        }
      });
    });

    async function loadCountries() {
      try {
        const res = await fetch("https://restcountries.com/v3.1/all?fields=name,idd,cca2");
        const countries = await res.json();

        allCountries = countries
          .map((c) => {
            const dialCode = c.idd?.root
              ? `${c.idd.root}${c.idd.suffixes?.[0] || ""}`
              : "";

            return {
              name: c.name?.common || "",
              code: c.cca2 || "",
              dialCode,
            };
          })
          .filter((c) => c.name && c.dialCode)
          .sort((a, b) => a.name.localeCompare(b.name));

        renderCountryList(allCountries);
      } catch (err) {
        console.error("Country load error:", err);
        showToast(false, "Failed to load countries.");
      }
    }


    function renderCountryList(list) {
      countryList.innerHTML = "";

      if (!list.length) {
        countryList.innerHTML = `<div>No country found</div>`;
        return;
      }

      list.forEach((c) => {
        const div = document.createElement("div");

        div.innerText = c.name;
        div.dataset.name = c.name;
        div.dataset.dialCode = c.dialCode;

        div.addEventListener("click", function () {
          selectedCountry = this.dataset.name;
          selectedDialCode = this.dataset.dialCode;

          selectedBox.innerText = selectedCountry;
          optionsContainer.style.display = "none";

          countryCodeHint.innerText = `Country code: ${selectedDialCode}`;
          phoneInput.value = "";
          phoneInput.setAttribute("maxlength", selectedCountry === "India" ? "10" : "15");

          countrySearch.value = "";
          renderCountryList(allCountries);
        });

        countryList.appendChild(div);
      });
    }


    countrySearch.addEventListener("input", function () {
      const keyword = this.value.toLowerCase().trim();

      const filtered = allCountries.filter((c) =>
        c.name.toLowerCase().includes(keyword) ||
        c.code.toLowerCase().includes(keyword) ||
        c.dialCode.includes(keyword)
      );

      renderCountryList(filtered);
    });


    phoneInput.addEventListener("input", function () {
      this.value = this.value.replace(/\D/g, "");

      if (selectedCountry === "India") {
        this.value = this.value.slice(0, 10);
      } else {
        this.value = this.value.slice(0, 15);
      }
    });

    loadCountries();

    selectedDialCode = "";
    selectedCountry = "";
    countryCodeHint.innerText = "Select country to show calling code";
    phoneInput.value = "";
    phoneInput.removeAttribute("maxlength");

    selectedBox.addEventListener("click", function () {
      optionsContainer.style.display =
        optionsContainer.style.display === "block" ? "none" : "block";

      setTimeout(() => {
        countrySearch.focus();
      }, 50);
    });

    // close on outside click
    document.addEventListener("click", function (e) {
      if (!document.getElementById("countryDropdown").contains(e.target)) {
        optionsContainer.style.display = "none";
      }
    });

    document.getElementById("loginForm").addEventListener("submit", async function (e) {
      e.preventDefault();

      const sponsorCode = document.getElementById("sponsorCode").value.trim();
      const fullName = document.getElementById("fullName").value.trim();
      const email = document.getElementById("email").value.trim();
      const phone = phoneInput.value.trim();
      const country = selectedCountry;
      const otp = document.getElementById("otp").value.trim();
      const password = document.getElementById("password").value.trim();
      const confirmPassword = document.getElementById("confirmPassword").value.trim();
      const registerBtn = document.getElementById("registerBtn");

      if (!sponsorCode || !fullName || !email || !phone || !country || !password || !confirmPassword) {
        showToast(false, "Please fill all required fields.");
        return;
      }

      if (!selectedDialCode) {
        showToast(false, "Please select country.");
        return;
      }

      if (country === "India" && !/^\d{10}$/.test(phone)) {
        showToast(false, "Please enter valid 10 digit phone number.");
        return;
      }

      if (password.length < 6) {
        showToast(false, "Password must be at least 6 characters.");
        return;
      }

      if (password !== confirmPassword) {
        showToast(false, "Passwords do not match.");
        return;
      }

      try {
        registerBtn.disabled = true;
        registerBtn.innerText = otpSent ? "Registering..." : "Sending OTP...";

        if (!otpSent) {
          const response = await fetch("/api/send-register-otp", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({
              email,
              invitecode: sponsorCode,
            }),
          });

          const data = await response.json();

          if (data.status === true) {
            otpSent = true;
            registerBtn.innerText = "Register";
            showToast(true, "OTP sent to your email");
          } else {
            registerBtn.innerText = "Send OTP";
            showToast(false, data.message || "Failed to send OTP.");
          }

          registerBtn.disabled = false;
          return;
        }

        if (!otp) {
          registerBtn.disabled = false;
          registerBtn.innerText = "Register";
          showToast(false, "Please enter the correct OTP.");
          return;
        }

        const response = await fetch("/api/register", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({
            email,
            pwd: password,
            invitecode: sponsorCode,
            phone: `${selectedDialCode}${phone}`,
            country,
            full_name: fullName,
            otp,
          }),
        });

        const data = await response.json();

        if (data.status === true) {
          showToast(true, data.message || "Registration successful.");

          setTimeout(() => {
            window.location.href = "/login";
          }, 1200);
        } else {
          showToast(false, data.message || "Registration failed.");
          registerBtn.disabled = false;
          registerBtn.innerText = "Register";
        }
      } catch (err) {
        console.error(err);
        registerBtn.disabled = false;
        registerBtn.innerText = otpSent ? "Register" : "Send OTP";
        showToast(false, "Something went wrong. Please try again.");
      }
    });
  </script>


</body>