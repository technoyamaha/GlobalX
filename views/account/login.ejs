  <div id="gxToastContainer"></div>
  <style>
    #gxToastContainer {
      position: fixed;
      top: 24px;
      right: 24px;
      z-index: 999999;
      display: flex;
      flex-direction: column;
      gap: 12px;
    }

    .gx-toast {
      min-width: 280px;
      max-width: 360px;
      padding: 14px 16px;
      border-radius: 12px;
      color: #fff;
      font-size: 14px;
      font-weight: 600;
      box-shadow: 0 12px 30px rgba(0, 0, 0, 0.35);
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      animation: gxSlideIn 0.25s ease;
    }

    .gx-toast-success {
      background: linear-gradient(135deg, #16a34a, #22c55e);
    }

    .gx-toast-error {
      background: linear-gradient(135deg, #dc2626, #ef4444);
    }

    .gx-toast-close {
      cursor: pointer;
      font-size: 20px;
      line-height: 1;
      opacity: 0.9;
    }

    @keyframes gxSlideIn {
      from {
        transform: translateX(120%);
        opacity: 0;
      }

      to {
        transform: translateX(0);
        opacity: 1;
      }
    }
  </style>

  <script>
    function showToast(status, message) {
      const container = document.getElementById("gxToastContainer");
      if (!container) return console.error("Toast container not found");

      container.innerHTML = "";

      const toast = document.createElement("div");
      toast.className = `gx-toast ${status ? "gx-toast-success" : "gx-toast-error"}`;
      toast.innerHTML = `
      <span>${message}</span>
      <span class="gx-toast-close">&times;</span>
    `;

      container.appendChild(toast);

      toast.querySelector(".gx-toast-close").addEventListener("click", function () {
        toast.remove();
      });

      setTimeout(function () {
        toast.remove();
      }, 3000);
    }

    async function handleLogin(e) {
      e.preventDefault();

      const email = document.getElementById("email").value.trim();
      const password = document.getElementById("password").value.trim();
      const submitBtn = document.querySelector("#MainloginForm button[type='submit']");

      if (!email || !password) {
        showToast(false, "Email and password are required.");
        return;
      }

      try {
        submitBtn.disabled = true;
        submitBtn.innerText = "Signing In...";

        const response = await fetch("/api/login", {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
          },
          body: JSON.stringify({
            email,
            pwd: password,
          }),
        });

        const data = await response.json();

        if (data.status === true) {
          document.cookie = `token=${data.token}; path=/; max-age=172800`;
          document.cookie = `auth=${data.hashedToken}; path=/; max-age=172800`;

          showToast(true, data.message || "Login successful!");

          setTimeout(() => {
            window.location.assign("/dashboard");
          }, 800);
        } else {
          showToast(false, data.message || "Invalid email or password.");
          submitBtn.disabled = false;
          submitBtn.innerText = "Sign In";
        }
      } catch (error) {
        console.error("Login Error:", error);
        showToast(false, "Something went wrong during login.");
        submitBtn.disabled = false;
        submitBtn.innerText = "Sign In";
      }
    }

    document.getElementById("MainloginForm").addEventListener("submit", handleLogin);


    // Password toggle (show/hide with icon change)
    document.querySelectorAll(".input-icon-eye").forEach((eyeWrapper) => {
      eyeWrapper.style.cursor = "pointer";

      eyeWrapper.addEventListener("click", function () {
        const input = this.parentElement.querySelector("input");
        const icon = this.querySelector("svg");

        if (!input || !icon) return;

        if (input.type === "password") {
          // Show password
          input.type = "text";

          // Change to eye-off icon
          icon.innerHTML = `
        <path d="M17.94 17.94A10.94 10.94 0 0 1 12 19C7 19 2.73 15.11 1 12c.73-1.31 1.71-2.61 2.92-3.79M9.88 9.88A3 3 0 0 0 12 15a3 3 0 0 0 2.12-.88M1 1l22 22"></path>
        <path d="M10.58 5.09A10.94 10.94 0 0 1 12 5c5 0 9.27 3.89 11 7-1 1.73-2.45 3.34-4.22 4.54"></path>
      `;
        } else {
          // Hide password
          input.type = "password";

          // Change to eye icon
          icon.innerHTML = `
        <path d="M2.062 12.348a1 1 0 0 1 0-.696 10.75 10.75 0 0 1 19.876 0 1 1 0 0 1 0 .696 10.75 10.75 0 0 1-19.876 0"></path>
        <circle cx="12" cy="12" r="3"></circle>
      `;
        }
      });
    });
  </script>
