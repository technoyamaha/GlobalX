<div id='cryptoon-layout' class="theme-orange">
  <!-- <div id="toast"></div> -->
  <div id="toast">
    <span id="toast-message"></span>
    <span id="toast-close" onclick="hideToast()"> ×</span>
  </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

<script>
  document
    .getElementById("changePasswordForm")
    .addEventListener("submit", function (e) {
      e.preventDefault();

      const currentPassword = document.getElementById("currentPassword").value;
      const newPassword = document.getElementById("newPassword").value;
      const confirmPassword = document.getElementById("confirmPassword").value;

      if (newPassword !== confirmPassword) {
        showToast(false, "new password do not match");
        return;
      }

      // Send request to backend
      fetch("/api/user/change-password", {
        method: "POST",
        credentials: "include",
        headers: {
          "Content-Type": "application/json",
        },
        body: JSON.stringify({
          currentPassword,
          newPassword,
        }),
      })
        .then((response) => {
          if (!response.ok) {
            // throw new Error("Password update failed");
        showToast(false, response.message || "Login failed");

          }
          return response.json();
        })
        .then((data) => {
           showToast(true, "Password changed successfully.");
          // Optionally close the modal
          const modal = bootstrap.Modal.getInstance(
            document.getElementById("ChangePasswordModal")
          );
          modal.hide();
        })

        .catch((error) => {
          alert("Error: " + error.message);
        });
    });

  $.ajax({
    url: "/api/user/info",
    type: "GET",
    success: function (response) {
      if (response.status) {
        const user = response.user || {};

        const email = document.getElementById("email");
        const phone = document.getElementById("phone");
        email.innerHTML = `${user.email}`;
        phone.innerHTML=` ${user.phone}`
 
      } else {
        console.warn("Unauthorized or user not found");
      }
    },
    error: function (xhr) {
      console.error("Failed to fetch user info:", xhr);
    },
  });
   function showToast(status, message) {
    const toast = document.getElementById("toast");
    const toastMessage = document.getElementById("toast-message");
    let toastTimeout;
    toastMessage.innerText = message;

    toast.classList.remove("bg-success1", "bg-danger1");
    toast.classList.add(status ? "bg-success1" : "bg-danger1");
    toast.classList.add("show");

    clearTimeout(toastTimeout);
    toastTimeout = setTimeout(() => {
      hideToast();
    }, 3000);
  }

  function hideToast() {
    const toast = document.getElementById("toast");
    toast.classList.remove("show");
  }
</script>
