  <script>
    function showToast(status, message) {
    const toast = document.getElementById("toast");
    const toastMessage = document.getElementById("toast-message");
    let toastTimeout;
    toastMessage.innerText = message;

    toast.classList.remove("bg-success1", "bg-danger1");
    toast.classList.add(status ? "bg-success1" : "bg-danger1");
    toast.classList.add("show");

    clearTimeout(toastTimeout);
    toastTimeout = setTimeout(() => {
      hideToast();
    }, 3000);
  }

  function hideToast() {
    const toast = document.getElementById("toast");
    toast.classList.remove("show");
  }



var toastTimeout = null;
function showToast(status, message) {
  const toast = document.getElementById("toast");
  const toastMessage = document.getElementById("toast-message");
  toastMessage.innerText = message;

  toast.classList.remove("bg-success1", "bg-danger1");
  toast.classList.add(status ? "bg-success1" : "bg-danger1");
  toast.classList.add("show");

  if (toastTimeout) clearTimeout(toastTimeout);
  toastTimeout = setTimeout(() => {
    hideToast();
  }, 3000);
}

function hideToast() {
  const toast = document.getElementById("toast");
  toast.classList.remove("show");
  if (toastTimeout) {
    clearTimeout(toastTimeout);
    toastTimeout = null;
  }
}

/* --- Option A: inline edit (no modal) --- */
/* Enable editing when Edit clicked */
$("#editProfileBtn").on("click", function(e) {
  e.preventDefault();
  // enable the editable fields
  $("#input-fullname, #input-phone").prop("readonly", false).focus();
  $("#input-country").prop("disabled", false);

  // Visual: mark button as editing (optional)
  $(this).addClass("editing");
});

/* Profile save AJAX — reuses your /api/updateProfile endpoint */
$("#profileForm").on("submit", function(e) {
  e.preventDefault();

  const data = {
    full_name: $("#input-fullname").val().trim(),
    phone: $("#input-phone").val().trim(),
    country: $("#input-country").val()
  };

  // Basic client-side validation
  if (!data.full_name || !data.phone || !data.country) {
    showToast(false, "Please fill all fields before saving.");
    return;
  }

  $.ajax({
    url: "/api/updateProfile",
    type: "POST",
    data: JSON.stringify(data),
    contentType: "application/json",
    success: function(response) {
      if (response && response.status) {
        showToast(true, "Profile updated successfully!");

        // Disable inputs again
        $("#input-fullname, #input-phone").prop("readonly", true);
        $("#input-country").prop("disabled", true);

        // Update mini-card username/other UI if needed
        // (username is readonly and not changed here, but if you ever allow changing it, update here)
        var displayName = $("#input-username").val() || $("#auth-username").text();
        $("#auth-username").text(displayName);

        // Optional: update last-login text from server or keep unchanged
        // You could also re-fetch /api/info to refresh all fields; simple approach keeps it minimal

        
        $("#editProfileBtn").removeClass("editing");

      } else {
        showToast(false, response && response.message ? response.message : "Update failed");
      }
    },
    error: function(xhr) {
      if (xhr && xhr.status === 401) {
        window.location.href = "/login";
        return;
      }
      console.error("Update failed:", xhr);
      showToast(false, "Update request failed. Check console.");
    }
  });
});

 function fmtMoney(n) {
      const num = Number(n) || 0;
      return '$ ' + num.toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 });
  }

  $.ajax({
  url: "/api/info",
  method: "GET",
  dataType: "json",
  cache: false,
  success: function(res) {

    if (!res || !res.status) {
      console.warn("Invalid /api/info response", res);
      return;
    }

    const user = res.user;
    const lastLogin = res.last_login || (res.last_5_login?.[0] || null);

    // Fill profile inputs
    $("#input-username").val(user.user_name || "");
    $("#input-email").val(user.email || "");
    $("#input-fullname").val(user.full_name || "");
    $("#input-phone").val(user.phone || "");

    if (user.country) {
      $("#input-country").val(String(user.country));
    }

    if (user.withdrawable_balance !== undefined && user.withdrawable_balance !== null) {
      $('.withdrawBalance').text(fmtMoney(user.withdrawable_balance));
    } 
    if (user.money ) $('.depositedMoney').text(fmtMoney(user.money));
    

    // Right side card
    $("#auth-username").text(user.user_name || "—");

    let raw =
      lastLogin?.today ||
      lastLogin?.login_at ||
      lastLogin?.time ||
      lastLogin?.date ||
      null;

    if (raw) {
      let dt = /^\d+$/.test(raw) ? new Date(Number(raw)) : new Date(raw);
      if (!isNaN(dt.getTime())) {
        const d = dt.toLocaleDateString(undefined, { year: "numeric", month: "short", day: "2-digit" });
        const t = dt.toLocaleTimeString(undefined, { hour: "2-digit", minute: "2-digit" });
        $("#auth-last-login").text(`${d} · ${t}`);
      } else {
        $("#auth-last-login").text(raw);
      }
    } else {
      $("#auth-last-login").text("—");
    }
  },

  error: function(xhr) {
    if (xhr.status === 401) {
      window.location.href = "/login";
    }
    console.error("Profile AJAX error:", xhr.responseText);
  }
});


// Logout Here
let logoutModal = null;

$(document).ready(function () {
  logoutModal = new bootstrap.Modal(
    document.getElementById("logoutConfirmModal")
  );

  $("#logoutBtn").on("click", function (e) {
    e.preventDefault();
    logoutModal.show();
  });

  $("#confirmLogoutBtn").on("click", function () {
    $("#confirmLogoutBtn").prop("disabled", true);

    $.ajax({
      url: "/api/logout",
      type: "POST",
      success: function (res) {
        if (res && res.status) {
          window.location.href = "/login";
        } else {
          showToast(false, "Logout failed");
          $("#confirmLogoutBtn").prop("disabled", false);
        }
      },
      error: function () {
        showToast(false, "Logout request failed");
        $("#confirmLogoutBtn").prop("disabled", false);
      },
    });
  });
});
  </script>

