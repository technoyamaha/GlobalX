<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>


<script>
  let currentPage = 1;
  const limit = 10;

  function formatDate(dateStr) {
    if (!dateStr) return '-';
    const date = new Date(dateStr);
    if (isNaN(date)) return '-';
    return date.toLocaleDateString();
  }

  function fetchData(page) {
    if (page < 1) return;

    $.ajax({
      url: `/api/mining-income?page=${page}&limit=${limit}`,
      method: 'GET',
      success: function (response) {
        const { data, totalPages } = response;
        currentPage = page;

        const tbody = $('table tbody');
        tbody.empty();

        if (!data || data.length === 0) {
          tbody.append(`
            <tr>
              <td colspan="4" class="text-center text-muted">No Mining Income Found</td>
            </tr>
          `);
        } else {
          data.forEach((item, index) => {
            tbody.append(`
              <tr>
                <td>${(currentPage - 1) * limit + index + 1}</td>
                <td class="text-center"><b>$${Number(item.earned_amount).toFixed(2)}</b></td>
                <td>${item.months ?? '-'}</td>
                <td>${formatDate(item.last_credited_date)}</td>
              </tr>
            `);
          });
        }

        // Render pagination only if totalPages > 1
        const pagination = $('#pagination');
        pagination.empty();

        if (totalPages > 1) {
          // Previous button
          pagination.append(`
            <li class="footable-page-nav ps-3 px-3 ${currentPage <= 1 ? 'disabled' : ''}" style="width: auto">
              <a class="footable-page-link" href="#" onclick="fetchData(${currentPage - 1}); return false;">« Previous</a>
            </li>
          `);

          // Page numbers
          for (let i = 1; i <= totalPages; i++) {
            pagination.append(`
              <li class="ps-3 px-3 footable-page visible ${i === currentPage ? 'active' : ''}" style="width: auto">
                <a class="footable-page-link" href="#" onclick="fetchData(${i}); return false;">${i}</a>
              </li>
            `);
          }

          // Next button
          pagination.append(`
            <li class="footable-page-nav ps-3 px-3 ${currentPage >= totalPages ? 'disabled' : ''}" style="width: auto">
              <a class="footable-page-link" href="#" onclick="fetchData(${currentPage + 1}); return false;">Next »</a>
            </li>
          `);
        }
      },
      error: function (error) {
        console.error('Error fetching mining income:', error);
        $('table tbody').html(`
          <tr><td colspan="4" class="text-center text-danger">Error loading data</td></tr>
        `);
      }
    });
  }

        // Initial fetch on page load
        $(document).ready(function() {
            fetchData(currentPage);
        });
    </script>

