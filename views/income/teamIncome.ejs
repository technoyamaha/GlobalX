<script
  src="https://cdnjs.cloudflare.com/ajax/libs/axios/1.7.1/axios.min.js"
  crossorigin="anonymous"
  referrerpolicy="no-referrer"
></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>

<div class="main px-lg-4 px-md-4">
  <%- include('../partials/header') %>
  <div class="body d-flex py-3">
    <div class="container-xxl">
      <div class="row align-items-center">
        <div class="border-0 mb-4">
          <div
            class="card-header py-3 no-bg bg-transparent d-flex align-items-center px-0 justify-content-between border-bottom flex-wrap"
          >
            <h3 class="fw-bold mb-0">Team Income</h3>
          </div>
        </div>
      </div>
      <div class="row">
        <div class="col-12">
          <div class="card mb-3">
            <div class="card-body">
              <div class="table-responsive">
                <table class="table table-hover">
                  <thead>
                    <tr>
                      <th scope="col">Sr.No</th>
                      <th scope="col">Income Amount</th>
                      <th scope="col">Date</th>
                      <th scope="col">From</th>
                      <th scope="col">Level</th>
                      <!-- <th scope="col">View Stats</th> -->
                    </tr>
                  </thead>
                  <tbody id="incomeTableBody">
                    <tr>
                      <td colspan="5">
                        <div class="col-auto text-center">No record found!</div>
                      </td>
                    </tr>
                  </tbody>
                </table>
              </div>
              <div class="row align-items-center"></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
<div id="pagination" class="mt-3"></div>

</div>


<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

<script>
  function renderTeamIncome(datas) {
    let html = "";
    if (datas && datas.length > 0) {
      datas.forEach((income, i) => {
        const fromUser =
          income.from_user_name && income.from_user_name.trim() !== ""
            ? income.from_user_name
            : income.from_user_id;

        html += `
        <tr>
          <td>${i + 1}</td>
          <td>${Number(income.amount).toFixed(2)}</td>
<td>${income.time.split(" ")[0]}</td>

          <td>${fromUser}</td>
          <td>Lvl ${income.level}</td>
        </tr>
      `;
      });
    } else {
      html = `
      <tr>
        <td colspan="5" class="text-center">No record found!</td>
      </tr>
    `;
    }
    $("#incomeTableBody").html(html);
  }


function renderPagination(pagination) {
    if (!pagination || pagination.totalPages <= 1) {
        $("#pagination").html('');  // no pagination needed
        return;
    }

    let html = `<nav aria-label="Page navigation"><ul class="pagination justify-content-center">`;

    // Previous button
    if (pagination.page > 1) {
        html += `<li class="page-item"><a class="page-link" href="#" data-page="${pagination.page - 1}">Previous</a></li>`;
    } else {
        html += `<li class="page-item disabled"><span class="page-link">Previous</span></li>`;
    }

    // Page numbers (you can customize this for large pages)
    for (let p = 1; p <= pagination.totalPages; p++) {
        if (p === pagination.page) {
            html += `<li class="page-item active"><span class="page-link">${p}</span></li>`;
        } else {
            html += `<li class="page-item"><a class="page-link" href="#" data-page="${p}">${p}</a></li>`;
        }
    }

    // Next button
    if (pagination.page < pagination.totalPages) {
        html += `<li class="page-item"><a class="page-link" href="#" data-page="${pagination.page + 1}">Next</a></li>`;
    } else {
        html += `<li class="page-item disabled"><span class="page-link">Next</span></li>`;
    }

    html += `</ul></nav>`;

    $("#pagination").html(html);

    // Attach click event
    $("#pagination a.page-link").on("click", function (e) {
        e.preventDefault();
        const page = parseInt($(this).data("page"));
        if (!isNaN(page)) {
            loadTeamIncome(page);
        }
    });
}
let currentPage = 1;
const limit = 5; // or whatever you want per page

function loadTeamIncome(page = 1) {
    $.ajax({
        type: "GET",  // better to use GET for fetching data
        url: `/api/team-income?page=${page}&limit=${limit}`,
        dataType: "json",
        success: function (data) {
            if (data.status) {
                renderTeamIncome(data.data);
                renderPagination(data.pagination);
                currentPage = data.pagination.page;
            } else {
                showToast(false, data.message || "Failed to load team income");
                $("#incomeTableBody").html(`
                    <tr>
                        <td colspan="5" class="text-center">No record found!</td>
                    </tr>
                `);
                $("#pagination").html(''); // clear pagination
            }
        },
        error: function () {
            showToast(false, "Server error while fetching Team Income");
            $("#incomeTableBody").html(`
                <tr>
                    <td colspan="5" class="text-center">Server error</td>
                </tr>
            `);
            $("#pagination").html(''); // clear pagination
        }
    });
}

  loadTeamIncome();
 
</script>
