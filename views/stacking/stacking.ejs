<script> 

async function loadCryptoPlans() {
  try {
    const response = await fetch('/api/plans');
    const result = await response.json();

    if (!result.success) {
      console.error("Failed to load plans");
      document.getElementById('plans-list').innerHTML = '<p class="text-muted">No plans available.</p>';
      return;
    }

    const plans = result.data || [];
    const container = document.getElementById('plans-list');
    container.innerHTML = '';

    if (!plans.length) {
      container.innerHTML = '<p class="text-muted">No plans available.</p>';
      return;
    }

    // Sort by min (numeric; null treated as Infinity so comes last)
    plans.sort((a, b) => {
      const am = a.min === null ? Infinity : Number(a.min);
      const bm = b.min === null ? Infinity : Number(b.min);
      return am - bm;
    });

    // Build cards using the Collection UI style
    const fragment = document.createDocumentFragment();
    plans.forEach(plan => {
      const minText = plan.min === null ? 'Any' : plan.min;
      const maxText = plan.max === null ? 'Unlimited' : plan.max;
      const daily = plan.daily_percent;

      const card = document.createElement('div');
      card.className = 'canvas-box';
      card.innerHTML = `
        <div class="cnvas-top-img-wrp">
          <img src="/assets/images/collection-tab-img-1.png" alt="image">
          <div class="blue-right-corner-wrp">
            <span><img src="/assets/images/collection-tab-right-icon.svg" alt="icon"></span>
            <span>${daily}%</span>
          </div>
        </div>

        <div class="canvas-bottom-cnt-wrp">
          <h4>${escapeHtml(plan.name || 'Plan')}</h4>

          <div class="amount-canvas-wrp">
            <div class="amount-1st">
              <span>Amount</span>
              <span class="green-amount">${minText} - ${maxText}</span>
            </div>

            <div class="amount-1st">
              <span>Daily income</span>
              <span class="card-rate-daily-income">${daily}%</span>
            </div>

            <div class="amount-1st">
              <span>Fees</span>
              <span class="card-rate-daily-income">0%</span>
            </div>
          </div>

          <div class="canvas-days-wrp">
            <div class="days-ten-outer">
              <span>Time</span>
              <span class="days-ten-highilited">${plan.months} months</span>
            </div>
            <div class="level-canvas-div">
              <span>Level:</span>
              <span class="green">Lv1 ~ Lv6</span>
            </div>
          </div>

          <div style="display:flex;gap:8px;align-items:center;margin-top:10px">
            <button class="btn btn-sm btn-primary mine-btn" 
                    data-plan-id="${plan.id}" 
                    data-min="${plan.min === null ? '' : plan.min}" 
                    data-max="${plan.max === null ? '' : plan.max}">
              Mine
            </button>
            <button class="btn btn-sm btn-outline-secondary details-btn" data-plan-id="${plan.id}">Details</button>
          </div>
        </div>
      `;

      fragment.appendChild(card);
    });

    container.appendChild(fragment);

    // (Optional) Details button handler — keeps original details behavior if you want to implement later
    document.querySelectorAll('.details-btn').forEach(dbtn => {
      dbtn.addEventListener('click', function () {
        const planId = this.getAttribute('data-plan-id');
        // if you had a details modal you can open it here.
        // For now just console log (no change to existing flow)
        console.log('Details requested for plan', planId);
      });
    });

  } catch (error) {
    console.error("Error loading plans:", error);
  }
}

// small helper to avoid injection in card titles
function escapeHtml(text) {
  if (text === null || text === undefined) return '';
  return String(text)
    .replace(/&/g, "&amp;")
    .replace(/</g, "&lt;")
    .replace(/>/g, "&gt;")
    .replace(/"/g, "&quot;")
    .replace(/'/g, "&#039;");
}

loadCryptoPlans();



  function deleteAllCookies() {
    document.cookie.split(";").forEach((cookie) => {
      const eqPos = cookie.indexOf("=");
      const name = eqPos > -1 ? cookie.substring(0, eqPos) : cookie;
      document.cookie = name + "=;expires=Thu, 01 Jan 1970 00:00:00 GMT;path=/";
    });
  }

  document.addEventListener("DOMContentLoaded", function() {
    const signoutBtn = document.getElementById("signoutBtn");

    if (signoutBtn) {
      signoutBtn.addEventListener("click", function(e) {
        e.preventDefault();
        deleteAllCookies();
        localStorage.clear();
        window.location.href = "/login";
      });
    }
  });

  let selectedAmount = null;

  function validateForm() {
    const canStart = selectedAmount !== null && selectedAmount >= 50;
    $("#startStakingBtn").prop("disabled", !canStart);
  }

  // Handle user typing in the amount
  $(document).on("input", "#amountInput", function() {
    const val = Number($(this).val().trim());
    selectedAmount = !isNaN(val) && val > 0 ? val : null;

    if (selectedAmount !== null && selectedAmount < 50) {
      showToast(false, "Minimum amount is $50.");
      selectedAmount = null;
    }

    validateForm();
  });

  // On start mining button click
  $(document).on("click", "#startStakingBtn", function() {
    if (!selectedAmount) {
      showToast(false, "Please enter a valid amount before proceeding!");
      return;
    }

    const payload = {
      amount: selectedAmount 
    };

    console.log("Sending Payload:", payload);



(function () {
  // helper: safe show toast
  function safeToast(ok, msg) {
    try {
      if (typeof showToast === "function") {
        showToast(ok, msg);
        return;
      }
    } catch (e) {}
    alert(msg);
  }

  // attach listeners when plan rows are present in DOM (they are added async)
  function attachPlanClickHandlers() {
    // plan rows markup created by loadCryptoPlans() uses `.d-flex.justify-content-between.my-2`
    const rows = Array.from(document.querySelectorAll('#plans-container .d-flex.justify-content-between.my-2'));

    if (!rows.length) return false;

    rows.forEach((row) => {
      // avoid double-binding
      if (row.__mineBound) return;
      row.__mineBound = true;

      // read the min value from the left part's text. Example text format generated:
      // "• 50 USDT – 100 USDT"  or "• 50 USDT & above"
      const leftText = row.children[0]?.textContent?.trim() || '';
      let min = 50; // safe default
      const m = leftText.match(/(\d+(\.\d+)?)/);
      if (m) min = Math.max(min, Number(m[1])); // ensure at least 50

      // Make row look clickable
      row.style.cursor = 'pointer';
      row.title = `Click to invest (min ${min})`;

      row.addEventListener('click', async () => {
        // Ask user for amount (prefill with min)
        const minAllowed = Math.max(50, min);
        let entered = window.prompt(`Enter amount to invest (minimum ${minAllowed}):`, String(minAllowed));
        if (entered === null) return; // user cancelled

        entered = String(entered).replace(/,/g, '').trim();
        const amount = Number(entered);
        if (!amount || isNaN(amount) || amount < minAllowed) {
          safeToast(false, `Invalid amount. Minimum is ${minAllowed}.`);
          return;
        }

        // Confirm one more time (optional; remove if you don't want)
        const confirmMsg = `Invest $${amount.toFixed(2)} in this plan?`;
        if (!window.confirm(confirmMsg)) return;

        // Send AJAX POST to /api/invest (same style as your existing code)
        try {
          $.ajax({
            url: "/api/invest",
            method: "POST",
            contentType: "application/json",
            data: JSON.stringify({ amount: amount }),
            success: function (res) {
              safeToast(res.status == 201, res.message || "Investment created");
              setTimeout(() => {
                location.reload();
              }, 1500);
            },
            error: function (xhr) {
              const msg = xhr?.responseJSON?.message || "Something went wrong while creating investment!";
              safeToast(false, msg);
              setTimeout(() => location.reload(), 1500);
            }
          });
        } catch (err) {
          console.error("Invest AJAX error", err);
          safeToast(false, "Request failed.");
        }
      });
    });

    return true;
  }

  // Poll for plan rows for a short time (they're rendered async)
  let tries = 0;
  const maxTries = 20;
  const t = setInterval(() => {
    const ok = attachPlanClickHandlers();
    if (ok || ++tries >= maxTries) clearInterval(t);
  }, 300);
})();


  });

  $.ajax({
  url: '/api/info',
  method: 'GET',
  dataType: 'json',
  cache: false,
  success: function(res) {
    if (!res || !res.status || !res.user) {
      console.warn('/api/info returned unexpected', res);
      return;
    }

    const user = res.user;
    const lastLogin = res.last_login || (Array.isArray(res.last_5_login) ? res.last_5_login[0] : null);

    function fmtMoney(n) {
      const num = Number(n) || 0;
      return '$ ' + num.toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 });
    }

    function fmtLastLogin(l) {
      if (!l) return '—';
      const raw = l.today || l.login_at || l.time || l.created_at || l.date || l.datetime || null;
      if (!raw) {
        const v = Object.values(l)[0];
        if (!v) return '—';
        return String(v);
      }
      let dt = /^\d+$/.test(String(raw)) ? new Date(Number(raw)) : new Date(raw);
      if (isNaN(dt.getTime())) return String(raw);
      const d = dt.toLocaleDateString(undefined, { year: 'numeric', month: 'short', day: '2-digit' });
      const t = dt.toLocaleTimeString(undefined, { hour: '2-digit', minute: '2-digit' });
      return `${d} · ${t}`;
    }

    if (user.withdrawable_balance !== undefined && user.withdrawable_balance !== null) {
      $('.withdrawBalance').text(fmtMoney(user.withdrawable_balance));
    } 
    if (user.money ) $('.depositedMoney').text(fmtMoney(user.money));
    
    if (res.totalWithdrawAmount) $('.totalWithdraw').text(fmtMoney(res.totalWithdrawAmount));
    $('#lastActivity').text(fmtLastLogin(lastLogin));

  },
  error: function(xhr) {
    if (xhr && xhr.status === 401) {
      window.location.href = '/login';
      return;
    }
    console.error('/api/info error', xhr && xhr.responseText);
  }
});

</script>


<script>
(function () {
  // Modal elements
  const modal = document.getElementById('investModal');
  const backdrop = document.getElementById('cvModalBackdrop');
  const closeBtn = document.getElementById('cvModalClose');
  const cancelBtn = document.getElementById('cvCancelBtn');
  const confirmBtn = document.getElementById('cvConfirmBtn');
  const amountInput = document.getElementById('cvAmountInput');
  const planMeta = document.getElementById('cvPlanMeta');
  const validationMsg = document.getElementById('cvValidationMsg');
  const toast = document.getElementById('cvToast');

  let currentPlan = { id: null, min: null, max: null };

  function showModal() {
    modal.style.display = 'flex';
    // small entrance
    requestAnimationFrame(() => {
      modal.classList.add('cv-open');
    });
    amountInput.focus();
    amountInput.select();
  }

  function hideModal() {
    modal.style.display = 'none';
    validationMsg.textContent = '';
    amountInput.value = '';
    currentPlan = { id: null, min: null, max: null };
  }

  // Close handlers
  backdrop.addEventListener('click', hideModal);
  closeBtn.addEventListener('click', hideModal);
  cancelBtn.addEventListener('click', hideModal);
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape') hideModal(); });

  // Preset click binding (sets amount)
  document.querySelectorAll('.cv-chip').forEach(c => {
    c.addEventListener('click', () => {
      amountInput.value = c.getAttribute('data-val');
    });
  });

  // Show toast helper (uses showToast if available)
  function showCvToast(ok, message) {
    try {
      if (typeof showToast === 'function') {
        showToast(ok, message);
        return;
      }
    } catch (err) { /* ignore */ }

    // fallback visual toast
    toast.innerText = message;
    toast.style.display = 'block';
    toast.style.opacity = '1';
    setTimeout(() => {
      toast.style.transition = 'opacity .4s';
      toast.style.opacity = '0';
      setTimeout(() => toast.style.display = 'none', 420);
    }, 2000);
  }

  // Validate amount against plan min/max
  function validateAmount(value) {
    validationMsg.textContent = '';
    const num = Number(String(value).replace(/,/g,'').trim());
    if (!num || isNaN(num) || num <= 0) return { ok:false, msg: 'Enter a valid amount' };
    if (currentPlan.min && !isNaN(Number(currentPlan.min)) && num < Number(currentPlan.min)) {
      return { ok:false, msg: `Minimum amount is ${Number(currentPlan.min)}` };
    }
    // global business rule: minimum $50 (keeps your existing constraint)
    if (num < 50) return { ok:false, msg: 'Minimum amount is $50' };
    if (currentPlan.max && !isNaN(Number(currentPlan.max)) && num > Number(currentPlan.max)) {
      return { ok:false, msg: `Maximum amount is ${Number(currentPlan.max)}` };
    }
    return { ok:true, value: num };
  }

  // When Mine button clicked — open modal with prefilled plan values
  // We re-bind to .mine-btn (safe to re-run even if existing bindings exist)
  function bindMineButtons() {
    document.querySelectorAll('.mine-btn').forEach(btn => {
      // prevent double binding
      if (btn.__cvBound) return;
      btn.__cvBound = true;

      btn.addEventListener('click', () => {
        const planId = btn.getAttribute('data-plan-id') || null;
        const minAttr = btn.getAttribute('data-min') || '';
        const maxAttr = btn.getAttribute('data-max') || '';

        const parsedMin = minAttr === '' ? null : Number(minAttr);
        const parsedMax = maxAttr === '' ? null : Number(maxAttr);

        currentPlan.id = planId;
        currentPlan.min = (parsedMin && !isNaN(parsedMin)) ? parsedMin : null;
        currentPlan.max = (parsedMax && !isNaN(parsedMax)) ? parsedMax : null;

        // Build meta text
        let meta = `Plan: ${btn.closest('.canvas-box')?.querySelector('h4')?.textContent || 'Plan'}`;
        if (currentPlan.min) meta += ` · Min ${currentPlan.min}`;
        if (currentPlan.max) meta += ` · Max ${currentPlan.max}`;
        planMeta.textContent = meta;

        // Prefill input (plan min -> else 50)
        const defaultVal = currentPlan.min ? currentPlan.min : 50;
        amountInput.value = defaultVal;
        validationMsg.textContent = '';
        showModal();
      });
    });
  }

  // initial bind (if .mine-btn were already created)
  bindMineButtons();

  // Also attempt to re-bind after DOM changes (if your plan loader re-renders)
  // (safe: it checks __cvBound to prevent duplicates) 
  const observer = new MutationObserver(() => bindMineButtons());
  observer.observe(document.body, { childList: true, subtree: true });

  // Confirm invest
  confirmBtn.addEventListener('click', async () => {
    const entered = amountInput.value;
    const check = validateAmount(entered);
    if (!check.ok) {
      validationMsg.textContent = check.msg;
      return;
    }

    // Disable UI while processing
    confirmBtn.disabled = true;
    confirmBtn.innerText = 'Processing...';

    try {
      // Ajax POST to /api/invest (same style as your existing code)
      const payload = { amount: check.value };

      // jQuery style (you use jQuery in project)
      $.ajax({
        url: "/api/invest",
        method: "POST",
        contentType: "application/json",
        data: JSON.stringify(payload),

        success: function (res) {
          showCvToast(res.status == 201, res.message || "Investment created");
          setTimeout(() => {
            hideModal();
            location.reload();
          }, 1200);
        },

        error: function (xhr) {
          const msg = xhr?.responseJSON?.message || "Something went wrong while creating investment!";
          showCvToast(false, msg);
          confirmBtn.disabled = false;
          confirmBtn.innerText = 'Invest';
        }
      });

    } catch (err) {
      console.error("Invest request error:", err);
      showCvToast(false, "Network error");
      confirmBtn.disabled = false;
      confirmBtn.innerText = 'Invest';
    }
  });

  // If user edits amount manually, allow Enter key to confirm
  amountInput.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') {
      e.preventDefault();
      confirmBtn.click();
    }
  });

  // Expose tiny API for external scripts (if you want to open modal programmatically)
  window.cvInvestModal = {
    open: (plan) => {
      // plan: { id, min, max, title }
      try {
        currentPlan.id = plan.id || null;
        currentPlan.min = plan.min || null;
        currentPlan.max = plan.max || null;
        planMeta.textContent = plan.title || 'Plan';
        amountInput.value = currentPlan.min || 50;
        showModal();
      } catch (e) {}
    }
  };

})();
</script>

