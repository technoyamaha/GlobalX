<style>
/* ---------- Modal visuals ---------- */
.cv-modal { position: fixed; inset: 0; z-index: 99999; display: none; align-items: center; justify-content: center; font-family: Inter, system-ui, -apple-system, "Segoe UI", Roboto, Arial; }
.cv-modal-backdrop { position: absolute; inset: 0; background: linear-gradient(180deg, rgba(6,10,20,0.48), rgba(6,10,20,0.6)); backdrop-filter: blur(6px); transition: opacity .18s ease; }

/* panel */
.cv-modal-panel { position: relative; width: 94%; max-width: 520px; border-radius: 16px; background: linear-gradient(180deg, #ffffff, #f7fbff); box-shadow: 0 30px 70px rgba(2,6,23,0.18); overflow: hidden; z-index: 2; padding: 0; transform: translateY(12px) scale(.995); opacity:0; transition: transform .26s cubic-bezier(.2,.9,.2,1), opacity .20s ease; }

/* open state (use requestAnimationFrame in JS to add class) */
.cv-modal.cv-open .cv-modal-panel { transform: translateY(0) scale(1); opacity:1; }

/* header */
.cv-modal-top {
  display:flex;
  align-items:center;
  gap:12px;
  padding:18px 18px;
  background: linear-gradient(90deg, rgba(0,170,255,0.12), rgba(0,192,255,0.06));
  border-bottom: 1px solid rgba(2,6,23,0.03);
}
.cv-modal-badge {
  min-width:52px;
  height:52px;
  border-radius:12px;
  display:grid;
  place-items:center;
  background: linear-gradient(135deg,#00aaff,#0078b5);
  color:white;
  font-weight:800;
  font-size:18px;
  box-shadow: 0 8px 26px rgba(0,170,255,0.12);
}
.cv-modal-title-wrap { flex:1; display:flex; flex-direction:column; gap:2px; }
.cv-modal-title { margin:0; font-size:18px; font-weight:800; color:#052033; letter-spacing: -0.2px; }
.cv-modal-sub { font-size:13px; color:#4b5563; }

/* close */
.cv-modal-close { background:transparent; border:0; font-size:20px; line-height:1; cursor:pointer; color:#0f172a; opacity:.7; }

/* body */
.cv-modal-body { padding:16px 18px 12px 18px; display:block; }
.cv-plan-meta { font-size:13px; color:#334155; margin-bottom:10px; font-weight:600; display:flex; gap:8px; align-items:center; }
.cv-plan-pill { background: rgba(2,120,185,0.08); color:#036280; padding:6px 10px; border-radius:999px; font-weight:700; font-size:13px; border:1px solid rgba(2,120,185,0.06); }

/* input row with currency prefix */
.cv-input-row { display:flex; gap:10px; align-items:center; margin-top:6px; }
.cv-currency {
  display:inline-flex; align-items:center; gap:8px; padding:10px 12px; border-radius:10px; background: linear-gradient(180deg,#fbfeff,#ffffff); border:1px solid rgba(2,6,23,0.05);
  font-weight:700; color:#0f172a; min-width:86px; justify-content:center;
}
#cvAmountInput { flex:1; padding:12px 12px; border-radius:10px; border:1px solid rgba(2,6,23,0.06); font-size:15px; outline:none; box-shadow:none; }
#cvAmountInput:focus { box-shadow: 0 10px 30px rgba(0,170,255,0.06); border-color: rgba(0,170,255,0.14); }

/* presets */
.cv-presets { display:flex; gap:8px; flex-wrap:wrap; margin-top:10px; }
.cv-chip { background: linear-gradient(180deg,#f0fbff,#ecfaff); border:1px solid rgba(0,170,255,0.08); padding:8px 12px; border-radius:12px; cursor:pointer; font-weight:800; color:#036; box-shadow: 0 6px 18px rgba(0,170,255,0.06); transition: transform .12s ease; }
.cv-chip:active { transform: translateY(1px); }

/* validation message */
.cv-validation { color:#b45309; margin-top:8px; font-size:13px; min-height:18px; }

/* footer */
.cv-modal-footer { display:flex; gap:10px; justify-content:flex-end; padding:12px 18px 18px 18px; border-top:1px solid rgba(2,6,23,0.03); }
.cv-btn { padding:10px 14px; border-radius:10px; cursor:pointer; font-weight:800; border:0; font-size:14px; }
.cv-btn-ghost { background:transparent; border:1px solid rgba(6,10,20,0.06); color:#334155; }
.cv-btn-primary { background: linear-gradient(90deg,#00aaff,#00c0ff); color:white; box-shadow: 0 12px 34px rgba(0,170,255,0.12); }

/* toast fallback */
.cv-toast { position: fixed; right: 20px; top: 20px; z-index: 100000; background: rgba(6,10,20,0.9); color:#fff; padding:10px 14px; border-radius:10px; box-shadow: 0 10px 30px rgba(2,6,23,0.22); font-weight:800; display:none; }

/* responsiveness */
@media (max-width:420px) {
  .cv-modal-panel { width: 96%; }
  .cv-modal-top { padding:12px; }
  .cv-modal-badge { min-width:44px; height:44px; font-size:16px; }
}
</style>

