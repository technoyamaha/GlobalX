<script>
  $(document).ready(async function () {
    let level = 1;
    let page = 1;
    const limit = 10;
    let total = 1;
    let search = "";

    $(".form-select").on("change", function () {
      const selectedValue = $(this).val();
      level = selectedValue;
      page = 1;
      console.log("Selected Level:", selectedValue);
      showUserByLevel(level, page);
    });
    let searchTimeout;

    $(".search-field").on("input", function () {
      clearTimeout(searchTimeout);
      search = $(this).val().trim();
      page = 1;
      searchTimeout = setTimeout(() => {
        showUserByLevel(level, page, search);
      }, 400);
    });

    const showUserByLevel = async (level, page) => {
      const response = await fetch("/api/user/teamByLevel", {
        method: "POST",
        headers: {
          "Content-type": "application/json",
        },
        body: JSON.stringify({
          level: level,
          page: page,
          limit: limit,
          search: search,
        }),
      });
      const usersByLevel = await response.json();
      if (usersByLevel.status == true) {
        total = Math.ceil(usersByLevel.total / limit);
        $(".current-page").html(page)
        RenderData(usersByLevel.data);
      }
    };

    showUserByLevel(level, page);

    function convertDate(unixMillis) {
      const ts = Number(unixMillis);
      if (isNaN(ts)) {
        throw new Error("Invalid timestamp: " + unixMillis);
      }
      const date = new Date(ts);
      const options = {
        timeZone: "Asia/Kolkata",
        day: "2-digit",
        month: "2-digit",
        year: "numeric",
      };
      const formatted = date.toLocaleDateString("en-GB", options);
      return formatted.replace(/\//g, "-");
    }

    function RenderData(datas) {

      if (datas.length == 0) {
        $(".levelusers-body").html(`<tr><td colspan="9" style="text-align:center;">No Record found for this level</td></tr>`);
        return;
      }
      let html = datas.map((data, index) => {
        return `
        <tr>
          <th scope="row">${index + 1 + limit * (page - 1)}</th>    
          <td>${data.id_user}</td>
          <td>${data.email}<br></td>
          <td class="tm-sz"><span>${data.tree_level}</span></td>
          <td class="busnes"><span>${data.total_downline}</span></td>  
          <td class="self-sub"><span>${convertDate(data.login_at)}</span></td>
          
        </tr>
        `;
      });
      $(".levelusers-body").html(html);
    }

    $(".next-page").on("click", () => {
      if (page >= total) {
        return;
      }
      page = page + 1;
      showUserByLevel(level, page);
    });

    $(".previous-page").on("click", () => {
      if (page == 1) {
        return;
      }
      page = page - 1;
      showUserByLevel(level, page);
    });
  });
</script>