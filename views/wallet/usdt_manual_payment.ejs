    <script src="https://code.jquery.com/jquery-3.6.4.min.js"></script>  

    <script>

    const SOURCE_TYPE = "<%= SourceType || 'usdt' %>";
  const alertMessage = (text) => {
    const msg = document.createElement("div");
    msg.setAttribute("data-v-1dcba851", "");
    msg.className = "msg";

    const msgContent = document.createElement("div");
    msgContent.setAttribute("data-v-1dcba851", "");
    msgContent.className = "msg-content v-enter-active v-enter-to";
    msgContent.style = "";
    msgContent.textContent = text;

    msg.appendChild(msgContent);
    document.body.appendChild(msg);

    setTimeout(() => {
      msgContent.classList.remove("v-enter-active", "v-enter-to");
      msgContent.classList.add("v-leave-active", "v-leave-to");
      // If you want to remove it from DOM after animation, uncomment below
      // setTimeout(() => {
      //   document.body.removeChild(msg);
      // }, 100);
    }, 1000);
  };

  // Copy wallet address (button at top)
  const copyWalletBtn = document.getElementById("copy_wallet_address_btn");

  copyWalletBtn.addEventListener("click", function () {
    const walletAddress = document
      .getElementById("wallet_address_field")
      .textContent.trim();

    const tempInput = document.createElement("textarea");
    tempInput.value = walletAddress;
    document.body.appendChild(tempInput);

    tempInput.select();
    document.execCommand("copy");
    document.body.removeChild(tempInput);

    // Feedback popup (you already had this)
    $("#refreshpopup").fadeIn(200);
    setTimeout(() => {
      $("#refreshpopup").fadeOut(200);
    }, 1000);
  });

  // Get loader overlays
  const loader = document.getElementById("loader");          // "Please wait / Payment in Progress"
  const loaderTick = document.getElementById("loader-tick"); // "Payment Successful / Hooray!"

  const submitButton = document.getElementById("submit_button");

  submitButton.addEventListener("click", async (event) => {
    event.preventDefault();

    try {
      const refNo = document.getElementById("ref_no").value; 
      const amount = "<%=Amount%>";

   
      if (!refNo) {
        alertMessage("Please enter transaction hash / reference number.");
        return;
      }
      const walletId = document.getElementById("wallet_id").value;

      const response = await axios.post(
  "/api/wallet/paynow/manual_usdt_request",
  {
    money: amount,
    utr: refNo,
    source: SOURCE_TYPE,
    wallet_id: walletId   
  }
);

      const result = response?.data;

      if (!result) {
        alertMessage("Something went wrong!");
        return;
      }

      // If demo redirect (same pattern as your UPI script)
      if (result.demo === true && result.url) {
        window.location.href = result.url;
        return;
      }

      // If backend says error
      if (result.status === false) {
        alertMessage(result.message || "Something went wrong!");
        return;
      }

      // SUCCESS REQUEST CREATED → show "Payment in Progress" loader
      // We expect backend to send recharge object like in manual UPI
      if (result.status === true && result.recharge) {
        const rechargeId = result.recharge.id;

        // Show progress overlay
        loader.style.display = "flex";
        loaderTick.style.display = "none";

        // Poll recharge status every 5 seconds
        const interval = setInterval(async () => {
          try {
            const statusResponse = await fetch(
              `/api/check_recharge_status?id=${rechargeId}`
            );
            const statusResult = await statusResponse.json();

            console.log("USDT recharge status:", statusResult);

            // status === 1 → Approved
            if (statusResult.status === 1) {
              loader.style.display = "none";
              loaderTick.style.display = "flex"; // Show success tick
              clearInterval(interval);

              // Redirect after showing success for 2 sec
              setTimeout(() => {
                // Change this if you want to go to /wallet/recharge instead
                window.location.href = "/wallet/deposit";
              }, 2000);
            }

            // Optional: handle failed/expired if your API returns other statuses
            if (statusResult.status === 2) {
              loader.style.display = "none";
              loaderTick.style.display = "none";
              clearInterval(interval);
              alertMessage(
                statusResult.message || "Payment failed or expired."
              );
            }
          } catch (err) {
            console.error("Error checking recharge status:", err);
            // Keep loader, we can ignore one-off error, or you could choose to stop polling:
            // clearInterval(interval);
            // loader.style.display = "none";
            // alertMessage("Error checking payment status.");
          }
        }, 5000);
      } else {
        // Fallback: no recharge object
        alertMessage(result.message || "Something went wrong!");
      }
    } catch (error) {
      console.log(error);
      alertMessage(
        error?.response?.data?.message || "Something went wrong!"
      );
    }
  });
    </script>
  
  </body>
</html>
