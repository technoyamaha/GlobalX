    <main>
      <header>
        <h2>USDT DEPOSIT</h2>
      </header>


      <div class="upi_display_root">
  <h2 class="upi_display_title">
    Send <%= Amount %> <%= PaymentCurrency || 'MV TOKEN' %> On
  </h2>

  <img
    id="upiQrImg"
